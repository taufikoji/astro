---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  darkNav?: boolean;
}

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;
const {
  title,
  description = 'STMK Trisakti – Sekolah Tinggi Media Komunikasi Trisakti, kampus multimedia terdepan di Jakarta. Program Desain Komunikasi Visual dan Teknologi Grafika berstandar industri.',
  image = url('/images/og-image.jpg'),
  darkNav = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.trisaktimultimedia.ac.id');
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="STMK Trisakti, multimedia, desain komunikasi visual, teknologi grafika, kampus multimedia Jakarta, kuliah desain, animasi, broadcasting, periklanan" />
    <meta name="author" content="STMK Trisakti" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | STMK Trisakti`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="STMK Trisakti" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | STMK Trisakti`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <title>{title} | STMK Trisakti</title>

    <!-- Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "CollegeOrUniversity",
        "name": "Sekolah Tinggi Media Komunikasi Trisakti",
        "alternateName": "STMK Trisakti",
        "url": "https://www.trisaktimultimedia.ac.id",
        "telephone": "+62-21-5663232",
        "email": "info@trisaktimultimedia.ac.id",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Jl. Jend. Achmad Yani 85
            Rawasari",
          "addressLocality": "Jakarta Timur",
          "addressRegion": "DKI Jakarta",
          "postalCode": "11440",
          "addressCountry": "ID"
        },
        "sameAs": [
          "https://www.instagram.com/stmktrisakti",
          "https://www.youtube.com/stmktrisakti"
        ]
      })}
    </script>
  </head>
  <body class="bg-[#FAFAF8] antialiased" data-dark-nav={darkNav ? 'true' : undefined}>
    <!-- Cursor glow — follows mouse, low opacity radial gradient -->
    <div id="cursor-glow" aria-hidden="true"></div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // ── 3D tilt effect for .tilt-card elements ──
      function initTilt() {
        document.querySelectorAll<HTMLElement>('.tilt-card').forEach(card => {
          if (card.dataset.tiltInit) return;
          card.dataset.tiltInit = '1';
          let raf = 0;
          card.addEventListener('mousemove', (e: MouseEvent) => {
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => {
              const rect = card.getBoundingClientRect();
              const x = (e.clientX - rect.left) / rect.width - 0.5;
              const y = (e.clientY - rect.top) / rect.height - 0.5;
              card.style.transform = `perspective(900px) rotateX(${-y*8}deg) rotateY(${x*8}deg) scale(1.015)`;
              card.style.transition = 'transform 0.08s ease-out';
            });
          });
          card.addEventListener('mouseleave', () => {
            cancelAnimationFrame(raf);
            card.style.transform = 'perspective(900px) rotateX(0) rotateY(0) scale(1)';
            card.style.transition = 'transform 0.55s cubic-bezier(0.23,1,0.32,1)';
          });
        });
      }
      initTilt();
      document.addEventListener('astro:page-load', initTilt);

      // ── Intersection Observer: reveal + stagger ──
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('visible');
          io.unobserve(entry.target);
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal, .stagger, .num-pop').forEach(el => io.observe(el));

      // ── Cursor glow ──
      const glowEl = document.getElementById('cursor-glow') as HTMLElement | null;
      if (glowEl) {
        let glowRaf = 0;
        document.addEventListener('mousemove', (e: MouseEvent) => {
          cancelAnimationFrame(glowRaf);
          glowRaf = requestAnimationFrame(() => {
            glowEl.style.left = e.clientX + 'px';
            glowEl.style.top  = e.clientY + 'px';
            glowEl.style.opacity = '1';
          });
        }, { passive: true });
        document.addEventListener('mouseleave', () => { glowEl.style.opacity = '0'; });
      }

      // ── Sticky header — dark-nav aware ──
      const header = document.getElementById('main-header');
      const isDarkNav = document.body.dataset.darkNav === 'true';
      const onScroll = () => {
        const scrolled = window.scrollY > 60;
        header?.classList.toggle('scrolled', scrolled);
        if (!isDarkNav) header?.classList.toggle('shadow-sm', scrolled);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // ── Animated number counter ──
      function animateCounter(el: HTMLElement) {
        const target = parseFloat(el.dataset.target || '0');
        const suffix = el.dataset.suffix || '';
        const duration = 1400;
        const start = performance.now();
        const isFloat = !Number.isInteger(target);

        function step(now: number) {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const value = target * eased;
          el.textContent = (isFloat ? value.toFixed(1) : Math.floor(value)).toString() + suffix;
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          animateCounter(el);
          counterObserver.unobserve(el);
        });
      }, { threshold: 0.5 });

      document.querySelectorAll('[data-target]').forEach(el => counterObserver.observe(el));

      // ── Smooth progress bars ──
      const barObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const bar = entry.target as HTMLElement;
          const w = bar.dataset.width || '0';
          setTimeout(() => { bar.style.width = w; }, 200);
          barObserver.unobserve(bar);
        });
      }, { threshold: 0.3 });

      document.querySelectorAll('[data-width]').forEach(el => barObserver.observe(el));
    </script>
  </body>
</html>

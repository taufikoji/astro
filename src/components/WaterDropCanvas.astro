---
interface Props {
  id?: string;
  opacity?: number;
  density?: number;   // drops per 10.000px² — default 4
}
const {
  id        = 'water-' + Math.random().toString(36).slice(2, 6),
  opacity   = 1,
  density   = 4,
} = Astro.props;
---

<canvas
  id={id}
  data-density={density}
  class="absolute inset-0 w-full h-full pointer-events-none select-none"
  style={`opacity:${opacity}; z-index:1`}
></canvas>

<script>
// ─────────────────────────────────────────────────────────────
// Water-on-glass canvas effect
// ─────────────────────────────────────────────────────────────

class Drop {
  x: number;
  y: number;
  r: number;
  vy: number;
  vx: number;
  stuck: boolean;
  trail: { x: number; y: number; r: number; a: number }[];
  alpha: number;
  dead: boolean;
  wobble: number;
  wobbleAmp: number;
  growCountdown: number;
  targetR: number;

  constructor(x: number, y: number, r: number, stuck = true) {
    this.x = x;
    this.y = y;
    this.r = stuck ? r * (0.3 + Math.random() * 0.5) : r; // stuck ones start small
    this.targetR = r;
    this.vy = 0;
    this.vx = 0;
    this.stuck = stuck;
    this.trail = [];
    this.alpha = 0.18 + Math.random() * 0.28;
    this.dead = false;
    this.wobble = Math.random() * Math.PI * 2;
    this.wobbleAmp = 0.4 + Math.random() * 0.6;
    this.growCountdown = Math.random() * 500 + 100;
  }

  update(W: number, H: number) {
    if (this.stuck) {
      // Grow slowly toward targetR
      if (this.growCountdown > 0) {
        this.growCountdown--;
      } else if (this.r < this.targetR) {
        this.r += 0.018;
      } else {
        // Once big enough, release
        if (this.r >= 10 && Math.random() < 0.0015) {
          this.stuck = false;
          this.vy = 0.5 + this.r * 0.08;
          this.vx = (Math.random() - 0.5) * 0.6;
        }
      }
      return;
    }

    // Gravity — larger drops fall faster
    this.vy += 0.10 + this.r * 0.005;
    this.vy = Math.min(this.vy, 6 + this.r * 0.3);  // terminal velocity
    this.vy *= 0.93;

    // Wobble left-right as it slides
    this.wobble += 0.07;
    this.vx += Math.sin(this.wobble) * this.wobbleAmp * 0.04;
    this.vx *= 0.88;

    this.x += this.vx;
    this.y += this.vy;

    // Leave trail droplets
    if (this.vy > 0.8 && Math.random() < 0.25) {
      this.trail.push({
        x: this.x + (Math.random() - 0.5) * this.r * 0.6,
        y: this.y - this.r * 0.9,
        r: 1 + Math.random() * this.r * 0.3,
        a: this.alpha * (0.3 + Math.random() * 0.4),
      });
    }
    if (this.trail.length > 18) this.trail.shift();

    // Off-screen
    if (this.y - this.r > H + 30 || this.x < -this.r || this.x > W + this.r) {
      this.dead = true;
    }
  }

  draw(ctx: CanvasRenderingContext2D) {
    // Draw trail first (back to front)
    for (const t of this.trail) {
      drawDrop(ctx, t.x, t.y, t.r, t.a, true);
    }
    drawDrop(ctx, this.x, this.y, this.r, this.alpha, false);
  }
}

// ─────────────────────────────────────────────────────────────
// Draw a single water droplet
// ─────────────────────────────────────────────────────────────
function drawDrop(
  ctx: CanvasRenderingContext2D,
  x: number, y: number, r: number,
  alpha: number, isTrail: boolean
) {
  if (r < 1 || alpha < 0.01) return;

  const rx = r * 0.82;   // slightly narrower than tall
  const ry = r;

  ctx.save();
  ctx.beginPath();
  ctx.ellipse(x, y, rx, ry, 0, 0, Math.PI * 2);
  ctx.clip();

  // ── 1. Base: very faint blue-white wash ──
  ctx.fillStyle = `rgba(210, 235, 255, ${alpha * 0.18})`;
  ctx.fill();

  // ── 2. Refraction body: inner-glow style ──
  const body = ctx.createRadialGradient(
    x - rx * 0.18, y - ry * 0.22, ry * 0.04,
    x + rx * 0.12, y + ry * 0.18, ry * 1.05
  );
  body.addColorStop(0,   `rgba(245, 252, 255, ${alpha * 0.28})`);
  body.addColorStop(0.35,`rgba(200, 228, 250, ${alpha * 0.14})`);
  body.addColorStop(0.72,`rgba(150, 195, 235, ${alpha * 0.18})`);
  body.addColorStop(1,   `rgba(80,  140, 210, ${alpha * 0.38})`);
  ctx.fillStyle = body;
  ctx.fill();

  if (!isTrail && r > 3) {
    // ── 3. Primary specular highlight (top-left crescent) ──
    const hl = ctx.createRadialGradient(
      x - rx * 0.30, y - ry * 0.38, 0,
      x - rx * 0.30, y - ry * 0.38, ry * 0.52
    );
    hl.addColorStop(0,   `rgba(255, 255, 255, 0.72)`);
    hl.addColorStop(0.38,`rgba(255, 255, 255, 0.22)`);
    hl.addColorStop(1,   `rgba(255, 255, 255, 0.00)`);
    ctx.fillStyle = hl;
    ctx.fill();

    // ── 4. Secondary specular (bottom-right, faint) ──
    if (r > 6) {
      const hl2 = ctx.createRadialGradient(
        x + rx * 0.42, y + ry * 0.52, 0,
        x + rx * 0.42, y + ry * 0.52, ry * 0.26
      );
      hl2.addColorStop(0, `rgba(255, 255, 255, 0.28)`);
      hl2.addColorStop(1, `rgba(255, 255, 255, 0.00)`);
      ctx.fillStyle = hl2;
      ctx.fill();
    }

    // ── 5. Bottom shadow (depth / thickness feel) ──
    const shadow = ctx.createRadialGradient(
      x, y + ry * 0.75, 0,
      x, y + ry * 0.38, ry * 0.85
    );
    shadow.addColorStop(0, `rgba(0, 25, 65, ${alpha * 0.38})`);
    shadow.addColorStop(1, `rgba(0, 25, 65, 0.00)`);
    ctx.fillStyle = shadow;
    ctx.fill();
  }

  ctx.restore();

  // ── 6. Rim: thin translucent edge ──
  ctx.save();
  ctx.beginPath();
  ctx.ellipse(x, y, rx, ry, 0, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(120, 170, 220, ${alpha * 0.55})`;
  ctx.lineWidth = r > 8 ? 1.1 : 0.6;
  ctx.stroke();
  ctx.restore();
}

// ─────────────────────────────────────────────────────────────
// Ripple (impact ring when a new drop appears)
// ─────────────────────────────────────────────────────────────
type Ripple = { x: number; y: number; r: number; maxR: number; a: number };

function drawRipple(ctx: CanvasRenderingContext2D, rpl: Ripple) {
  ctx.save();
  ctx.beginPath();
  ctx.arc(rpl.x, rpl.y, rpl.r, 0, Math.PI * 2);
  ctx.strokeStyle = `rgba(200, 230, 255, ${rpl.a})`;
  ctx.lineWidth = 1;
  ctx.stroke();
  ctx.restore();
}

// ─────────────────────────────────────────────────────────────
// Engine per canvas
// ─────────────────────────────────────────────────────────────
class WaterEngine {
  canvas: HTMLCanvasElement;
  ctx: CanvasRenderingContext2D;
  density: number;
  drops: Drop[];
  ripples: Ripple[];
  animId: number | null;
  frameCount: number;
  W: number;
  H: number;

  constructor(canvas: HTMLCanvasElement) {
    this.canvas  = canvas;
    this.ctx     = canvas.getContext('2d')!;
    this.density = parseFloat(canvas.dataset.density || '4');
    this.drops   = [];
    this.ripples = [];
    this.animId  = null;
    this.frameCount = 0;
    this.W = 0;
    this.H = 0;
    this.resize();
    window.addEventListener('resize', () => this.resize(), { passive: true });
  }

  resize() {
    const p = this.canvas.parentElement!;
    this.W = this.canvas.width  = p.offsetWidth  || window.innerWidth;
    this.H = this.canvas.height = p.offsetHeight || 500;
    this.init();
  }

  init() {
    const { W, H, density } = this;
    const count = Math.round((W * H) / 10000 * density);
    this.drops = [];

    for (let i = 0; i < count; i++) {
      const x = Math.random() * W;
      const y = Math.random() * H;
      const r = 2 + Math.random() * Math.random() * 28; // skewed toward small
      this.drops.push(new Drop(x, y, r, true));
    }
  }

  spawnNewDrop() {
    const { W } = this;
    const x = Math.random() * W;
    const y = -10;
    const r = 5 + Math.random() * 16;
    const d = new Drop(x, y, r, false);
    this.drops.push(d);
    this.ripples.push({ x, y: 0, r: 2, maxR: r * 2.5, a: 0.5 });
  }

  frame() {
    const { ctx, canvas, drops, ripples, W, H } = this;
    this.frameCount++;

    ctx.clearRect(0, 0, W, H);

    // Update & draw drops
    for (const d of drops) d.update(W, H);

    // Remove dead drops
    const before = drops.length;
    this.drops = drops.filter(d => !d.dead);
    // Replenish stuck drops if many died
    const died = before - this.drops.length;
    for (let i = 0; i < died; i++) {
      const x = Math.random() * W;
      const y = Math.random() * H;
      const r = 2 + Math.random() * Math.random() * 22;
      this.drops.push(new Drop(x, y, r, true));
    }

    // Draw drops back-to-front by size
    const sorted = [...this.drops].sort((a, b) => a.r - b.r);
    for (const d of sorted) d.draw(ctx);

    // Update & draw ripples
    for (const rpl of ripples) {
      rpl.r  += (rpl.maxR - rpl.r) * 0.07;
      rpl.a  *= 0.92;
      if (rpl.a > 0.01) drawRipple(ctx, rpl);
    }
    this.ripples = ripples.filter(r => r.a > 0.01);

    // Randomly spawn a new falling drop
    if (this.frameCount % 90 === 0 && Math.random() < 0.55) {
      this.spawnNewDrop();
    }

    this.animId = requestAnimationFrame(() => this.frame());
  }

  start() {
    if (this.animId) return;
    this.animId = requestAnimationFrame(() => this.frame());
  }

  stop() {
    if (this.animId) {
      cancelAnimationFrame(this.animId);
      this.animId = null;
    }
  }
}

// ─────────────────────────────────────────────────────────────
// Bootstrap — one engine per canvas with data-density attribute
// ─────────────────────────────────────────────────────────────
document.querySelectorAll<HTMLCanvasElement>('canvas[data-density]').forEach(canvas => {
  const engine = new WaterEngine(canvas);

  const io = new IntersectionObserver(entries => {
    entries.forEach(e => e.isIntersecting ? engine.start() : engine.stop());
  }, { threshold: 0 });

  io.observe(canvas);
});
</script>

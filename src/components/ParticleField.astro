---
interface Props {
  id?: string;
  count?: number;
  colors?: string[];
  opacity?: number;
  speed?: number;
  interactive?: boolean;
}
const {
  id = 'particles',
  count = 60,
  colors = ['#C8102E','#C850FF','#00E5FF','#FFAB00'],
  opacity = 0.6,
  speed = 0.4,
  interactive = true,
} = Astro.props;
---

<canvas
  id={id}
  class="absolute inset-0 w-full h-full pointer-events-none"
  style={`z-index:2;opacity:${opacity}`}
  aria-hidden="true"
></canvas>

<script define:vars={{ id, count, colors, speed, interactive }}>
(function() {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');

  let W = 0, H = 0, mouse = { x: -9999, y: -9999 };
  const particles = [];

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    W = canvas.width  = rect.width;
    H = canvas.height = rect.height;
  }
  resize();
  window.addEventListener('resize', resize, { passive: true });

  if (interactive) {
    canvas.parentElement.addEventListener('mousemove', (e) => {
      const rect = canvas.parentElement.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }, { passive: true });
    canvas.parentElement.addEventListener('mouseleave', () => {
      mouse.x = -9999; mouse.y = -9999;
    }, { passive: true });
  }

  function rand(min, max) { return Math.random() * (max - min) + min; }

  class Particle {
    constructor() { this.reset(true); }
    reset(init) {
      this.x  = rand(0, W);
      this.y  = init ? rand(0, H) : (Math.random() < 0.5 ? -10 : H + 10);
      this.r  = rand(1, 3);
      this.vx = rand(-speed, speed);
      this.vy = rand(-speed * 0.8, speed * 0.8) + (init ? 0 : (this.y < 0 ? speed : -speed));
      this.color = colors[Math.floor(Math.random() * colors.length)];
      this.alpha = rand(0.3, 1);
      this.life  = rand(0.002, 0.004);
      this.fade  = this.alpha;
      this.pulse = rand(0, Math.PI * 2);
      this.pulseSpeed = rand(0.02, 0.05);
    }
    update() {
      this.pulse += this.pulseSpeed;
      const glow = Math.sin(this.pulse) * 0.3 + 0.7;

      /* Mouse attraction */
      if (interactive) {
        const dx = mouse.x - this.x, dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 120 && dist > 0) {
          const force = (120 - dist) / 120 * 0.03;
          this.vx += (dx / dist) * force;
          this.vy += (dy / dist) * force;
        }
      }

      /* Damping */
      this.vx *= 0.99; this.vy *= 0.99;
      this.x += this.vx; this.y += this.vy;
      this.fade -= this.life;

      if (this.fade <= 0 || this.x < -20 || this.x > W + 20 || this.y < -20 || this.y > H + 20) {
        this.reset(false);
      }

      /* Draw */
      ctx.save();
      ctx.globalAlpha = Math.max(0, this.fade) * glow;
      ctx.fillStyle = this.color;
      ctx.shadowColor = this.color;
      ctx.shadowBlur = this.r * 5;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  for (let i = 0; i < count; i++) particles.push(new Particle());

  /* Connection lines between close particles */
  function drawLines() {
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const d  = Math.sqrt(dx * dx + dy * dy);
        if (d < 80) {
          ctx.save();
          ctx.globalAlpha = (1 - d / 80) * 0.12;
          ctx.strokeStyle = particles[i].color;
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
          ctx.restore();
        }
      }
    }
  }

  let animId;
  function loop() {
    ctx.clearRect(0, 0, W, H);
    drawLines();
    particles.forEach(p => p.update());
    animId = requestAnimationFrame(loop);
  }
  loop();

  /* Pause when not visible */
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { if (!animId) loop(); }
      else { cancelAnimationFrame(animId); animId = null; }
    });
  });
  observer.observe(canvas);
})();
</script>

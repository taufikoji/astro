---
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;
const navItems = [
  {
    label: 'Tentang',
    href: url('/tentang'),
    children: [
      { label: 'Profil Kampus',        href: url('/tentang') },
      { label: 'Sambutan Ketua',       href: url('/tentang/sambutan-ketua') },
      { label: 'Visi & Misi',          href: url('/tentang/visi-misi') },
      { label: 'Sejarah',              href: url('/tentang/sejarah') },
      { label: 'Struktur Organisasi',  href: url('/tentang/struktur-organisasi') },
    ],
  },
  {
    label: 'Program',
    href: url('/program'),
    children: [
      { label: 'Desain Komunikasi Visual', href: url('/program/dkv') },
      { label: 'Teknologi Grafika',        href: url('/program/teknologi-grafika') },
      { label: 'Dosen',                    href: url('/program/dosen') },
    ],
  },
  {
    label: 'Akademik',
    href: url('/akademik'),
    children: [
      { label: 'Penjaminan Mutu',    href: url('/akademik/penjaminan-mutu') },
      { label: 'Penelitian & PKM',   href: url('/akademik/penelitian') },
      { label: 'Kemahasiswaan',      href: url('/akademik/kemahasiswaan') },
      { label: 'Alumni',             href: url('/akademik/alumni') },
    ],
  },
  { label: 'Akreditasi', href: url('/akreditasi') },
  {
    label: 'Fasilitas',
    href: url('/fasilitas'),
    children: [
      { label: 'Overview Fasilitas', href: url('/fasilitas') },
      { label: 'Perpustakaan',       href: url('/fasilitas/perpustakaan') },
      { label: 'Laboratorium',       href: url('/fasilitas/laboratorium') },
      { label: 'Studio Podcast',     href: url('/fasilitas/podcast') },
    ],
  },
  {
    label: 'Konten',
    href: url('/berita'),
    children: [
      { label: 'Berita & Artikel', href: url('/berita') },
      { label: 'Jurnal',           href: url('/jurnal') },
      { label: 'Galeri',           href: url('/galeri') },
    ],
  },
  {
    label: 'Karir & Alumni',
    href: url('/karir-alumni'),
    children: [
      { label: 'Info Karir',        href: url('/karir-alumni') },
      { label: 'Job Vacancy',       href: url('/karir-alumni/job-vacancy') },
      { label: 'Testimoni Alumni',  href: url('/karir-alumni/testimoni') },
    ],
  },
  { label: 'Kontak', href: url('/kontak') },
];

const path = Astro.url.pathname;
---

<header id="main-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <div class="max-w-screen-xl mx-auto px-5 flex items-center h-[64px] gap-8">

    <!-- Logo -->
    <a href={url('/')} class="flex items-center gap-3 shrink-0">
      <img
        id="header-logo"
        src={url('/images/logo-stmk.png')}
        alt="Trisakti School of Multimedia"
        class="h-9 w-auto object-contain transition-all duration-300"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-0.5 flex-1" aria-label="Navigasi utama">
      {navItems.map(item => (
        <div class="relative group">
          <a
            href={item.href}
            class:list={[
              'header-nav-link px-3 py-2 flex items-center gap-1 text-sm font-medium transition-colors duration-150',
              path.startsWith(item.href) && item.href !== url('/') ? 'active' : '',
            ]}
          >
            {item.label}
            {item.children && (
              <svg class="w-3 h-3 opacity-40 transition-transform duration-150 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            )}
          </a>

          {item.children && (
            <div class="header-dropdown absolute top-full left-0 w-52 opacity-0 invisible
                        group-hover:opacity-100 group-hover:visible
                        translate-y-2 group-hover:translate-y-0 transition-all duration-200 z-50"
                 style="border-radius:3px">
              {item.children.map(c => (
                <a href={c.href}
                   class="header-dropdown-link block px-4 py-2.5 text-sm font-medium transition-colors border-b last:border-0">
                  {c.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-3 ml-auto lg:ml-0">
      <a href="https://siakad.trisaktimultimedia.ac.id" target="_blank" rel="noopener noreferrer"
         class="header-secondary hidden md:block text-xs font-medium transition-colors">
        SIAKAD
      </a>
      <a href={url('/pmb')} class="btn-primary hidden md:inline-flex py-2.5 text-xs">
        Daftar 2026/2027
      </a>
      <button id="menu-btn" class="lg:hidden p-2 header-menu-btn" aria-label="Menu">
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu — fixed overlay, scrollable -->
  <div id="mobile-menu" class="lg:hidden mobile-menu-wrap">
    <div class="px-5 py-3 pb-10">
      {navItems.map(item => (
        <div class="mobile-nav-group">
          <a href={item.href}
             class="mobile-nav-link flex items-center justify-between py-3.5 text-sm font-bold border-b transition-colors"
             style="border-color:var(--mob-border)">
            <span>{item.label}</span>
            {item.children && (
              <svg class="w-3.5 h-3.5 opacity-40 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
              </svg>
            )}
          </a>
          {item.children && (
            <div class="pl-4 pt-1 pb-1">
              {item.children.map(c => (
                <a href={c.href}
                   class="mobile-sub-link block py-2.5 text-sm transition-colors"
                   style="border-bottom:1px solid var(--mob-sub-border)">
                  {c.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="pt-5 pb-2">
        <a href={url('/pmb')} class="btn-primary w-full justify-center text-base py-4">
          Daftar 2026/2027 →
        </a>
      </div>
      <p class="text-center text-[11px] pt-4" style="color:var(--mob-muted)">+62 877 4299 7808 · Senin–Jumat 08.00–17.00</p>
    </div>
  </div>
</header>

<!-- Spacer so content starts below fixed header -->
<div class="h-[64px]" id="header-spacer"></div>

<style>
/* ═══════════════════════════════════════
   LIGHT MODE (default — inner pages)
═══════════════════════════════════════ */
#main-header {
  background: rgba(250,250,248,0.97);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(0,0,0,0.07);
}
#main-header.scrolled {
  box-shadow: 0 1px 20px rgba(0,0,0,0.06);
}
.header-nav-link        { color: #525252; }
.header-nav-link:hover  { color: #0a0a0a; }
.header-nav-link.active { color: #0a0a0a; font-weight: 700; }
.header-secondary       { color: #737373; }
.header-secondary:hover { color: #0a0a0a; }
.header-menu-btn        { color: #404040; }

.header-dropdown {
  background: rgba(255,255,255,0.98);
  border: 1px solid rgba(0,0,0,0.08);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
}
.header-dropdown-link       { color: #525252; border-color: rgba(0,0,0,0.05); }
.header-dropdown-link:hover { background: #f5f5f3; color: #0a0a0a; }

.mobile-menu-wrap { background: rgba(250,250,248,0.99); max-height: 0; transition: max-height 0.35s ease-out; }
.mobile-menu-wrap.open { max-height: 700px; }
.mobile-nav-link { color: #262626; }
.mobile-nav-link:hover { color: #C8102E; }

/* ═══════════════════════════════════════
   DARK NAV MODE (homepage + dark-hero pages)
═══════════════════════════════════════ */
body[data-dark-nav] #main-header {
  background: transparent;
  border-bottom-color: transparent;
  box-shadow: none;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
}
body[data-dark-nav] #main-header.scrolled {
  background: rgba(9,9,14,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 4px 32px rgba(0,0,0,0.4);
}

body[data-dark-nav] .header-nav-link        { color: rgba(255,255,255,0.65); }
body[data-dark-nav] .header-nav-link:hover  { color: rgba(255,255,255,1); }
body[data-dark-nav] .header-nav-link.active { color: white; font-weight: 700; }
body[data-dark-nav] .header-secondary       { color: rgba(255,255,255,0.4); }
body[data-dark-nav] .header-secondary:hover { color: rgba(255,255,255,0.9); }
body[data-dark-nav] .header-menu-btn        { color: rgba(255,255,255,0.8); }

/* Logo: keep original colors, add white pill backing so it's readable on dark */
body[data-dark-nav] #header-logo {
  background: rgba(255,255,255,0.93);
  padding: 4px 10px;
  border-radius: 4px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.4);
}

body[data-dark-nav] .header-dropdown {
  background: rgba(12,11,20,0.97);
  border: 1px solid rgba(255,255,255,0.09);
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 4px 16px rgba(0,0,0,0.3);
}
body[data-dark-nav] .header-dropdown-link       { color: rgba(255,255,255,0.6); border-color: rgba(255,255,255,0.06); }
body[data-dark-nav] .header-dropdown-link:hover { background: rgba(255,255,255,0.05); color: white; }

body[data-dark-nav] .mobile-menu-wrap { background: rgba(9,9,14,0.98); }
body[data-dark-nav] .mobile-nav-link  { color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.06); }
body[data-dark-nav] .mobile-nav-link:hover { color: var(--neon-cyan); }

/* Spacer: hide on dark-nav pages (hero is full height anyway) */
body[data-dark-nav] #header-spacer { display: none; }

/* ═══════════════════════════════════════
   MOBILE MENU OVERLAY
═══════════════════════════════════════ */
.mobile-menu-wrap {
  /* Fixed overlay, starts below header bar */
  position: fixed;
  top: 64px;
  left: 0; right: 0; bottom: 0;
  z-index: 49;

  /* Scroll */
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;

  /* Default (light) theme */
  background: #FAFAF8;
  --mob-border:     rgba(0,0,0,0.08);
  --mob-sub-border: rgba(0,0,0,0.05);
  --mob-muted:      #a3a3a3;

  /* Hidden by default */
  opacity: 0;
  pointer-events: none;
  transform: translateY(-6px);
  transition: opacity 0.25s ease, transform 0.28s cubic-bezier(0.23,1,0.32,1);
}
.mobile-menu-wrap.open {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

/* Light mode nav links */
.mobile-nav-link  { color: #1a1a1a; }
.mobile-nav-link:hover { color: var(--brand); }
.mobile-sub-link  { color: #525252; }
.mobile-sub-link:hover { color: #0a0a0a; }

/* Dark nav mode */
body[data-dark-nav] .mobile-menu-wrap {
  background: rgba(9,9,14,0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  --mob-border:     rgba(255,255,255,0.08);
  --mob-sub-border: rgba(255,255,255,0.05);
  --mob-muted:      #404040;
}
body[data-dark-nav] .mobile-nav-link  { color: rgba(255,255,255,0.85); }
body[data-dark-nav] .mobile-nav-link:hover { color: var(--neon-cyan); }
body[data-dark-nav] .mobile-sub-link  { color: rgba(255,255,255,0.45); }
body[data-dark-nav] .mobile-sub-link:hover { color: rgba(255,255,255,0.9); }
</style>

<script>
  const btn    = document.getElementById('menu-btn');
  const menu   = document.getElementById('mobile-menu');
  const iconO  = document.getElementById('icon-open');
  const iconC  = document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.add('open');
    iconO?.classList.add('hidden');
    iconC?.classList.remove('hidden');
    document.body.style.overflow = 'hidden'; /* prevent background scroll */
  }
  function closeMenu() {
    menu?.classList.remove('open');
    iconO?.classList.remove('hidden');
    iconC?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    menu?.classList.contains('open') ? closeMenu() : openMenu();
  });

  /* Close on nav link tap */
  menu?.querySelectorAll('a[href]').forEach(a => {
    a.addEventListener('click', closeMenu);
  });

  /* Close when screen becomes desktop */
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) closeMenu();
  }, { passive: true });
</script>

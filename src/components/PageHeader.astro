---
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;

interface Props {
  label: string;
  title: string;
  desc?: string;
  breadcrumb?: { label: string; href: string }[];
  tabs?: { label: string; href: string }[];
  currentPath?: string;
  accent?: 'red' | 'cyan' | 'purple' | 'amber' | 'green';
}

const {
  label, title, desc,
  breadcrumb = [],
  tabs = [],
  currentPath = '',
  accent = 'red',
} = Astro.props;

const accentColors: Record<string, { blob1: string; blob2: string; bar: string; glow: string; tabActive: string }> = {
  red:    { blob1: 'rgba(200,16,46,0.45)',   blob2: 'rgba(200,80,255,0.20)',  bar: 'var(--brand)',      glow: 'rgba(200,16,46,0.6)',   tabActive: 'var(--brand)' },
  cyan:   { blob1: 'rgba(0,229,255,0.35)',   blob2: 'rgba(200,16,46,0.20)',   bar: 'var(--neon-cyan)',  glow: 'rgba(0,229,255,0.6)',   tabActive: 'var(--neon-cyan)' },
  purple: { blob1: 'rgba(200,80,255,0.40)',  blob2: 'rgba(0,229,255,0.18)',   bar: 'var(--neon-purple)',glow: 'rgba(200,80,255,0.6)',  tabActive: 'var(--neon-purple)' },
  amber:  { blob1: 'rgba(255,171,0,0.38)',   blob2: 'rgba(200,16,46,0.20)',   bar: 'var(--neon-amber)', glow: 'rgba(255,171,0,0.6)',   tabActive: 'var(--neon-amber)' },
  green:  { blob1: 'rgba(0,230,118,0.35)',   blob2: 'rgba(0,229,255,0.18)',   bar: 'var(--neon-green)', glow: 'rgba(0,230,118,0.6)',   tabActive: 'var(--neon-green)' },
};
const ac = accentColors[accent];
---

<div class="relative overflow-hidden" style="background:#09090E; min-height: 220px;">

  <!-- Aurora blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="aurora-blob" style={`width:600px;height:500px;top:-120px;left:-80px;background:radial-gradient(circle,${ac.blob1} 0%,transparent 65%);animation:aurora-1 18s ease-in-out infinite;`}></div>
    <div class="aurora-blob" style={`width:500px;height:400px;top:-80px;right:-60px;background:radial-gradient(circle,${ac.blob2} 0%,transparent 65%);animation:aurora-3 22s ease-in-out infinite;`}></div>
    <div class="aurora-blob opacity-50" style="width:300px;height:300px;bottom:-80px;left:40%;background:radial-gradient(circle,rgba(200,80,255,0.15) 0%,transparent 65%);animation:aurora-2 25s ease-in-out infinite;"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 hero-grid opacity-30 pointer-events-none" aria-hidden="true"></div>

  <!-- Accent bar — left edge -->
  <div class="absolute top-0 left-0 bottom-0 w-[3px] z-10 pointer-events-none"
       style={`background:${ac.bar};box-shadow:0 0 15px ${ac.glow};`}
       aria-hidden="true"></div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none"
       style="background:linear-gradient(to top,#09090E 0%,transparent 100%); z-index:2"
       aria-hidden="true"></div>

  <!-- Large echo text in background -->
  <div class="absolute right-4 bottom-0 overflow-hidden leading-none select-none pointer-events-none"
       style="z-index:1" aria-hidden="true">
    <span class="font-black text-white block"
          style="font-size:clamp(4rem,14vw,11rem);letter-spacing:-0.05em;line-height:0.85;transform:translateY(25%);opacity:0.025;">
      {title.split(' ')[0].toUpperCase()}
    </span>
  </div>

  <!-- Content -->
  <div class="relative max-w-screen-xl mx-auto px-8 md:px-14 pt-12 pb-10" style="z-index:3">

    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav class="flex items-center gap-2 mb-6 fade-up" aria-label="Breadcrumb" style="animation-delay:0ms">
        <a href={url('/')} class="text-neutral-600 hover:text-white transition-colors text-xs font-medium">
          Beranda
        </a>
        {breadcrumb.map((b) => (
          <>
            <svg class="w-3 h-3 text-neutral-700 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
            {b.href ? (
              <a href={b.href} class="text-neutral-500 hover:text-white transition-colors text-xs font-medium">{b.label}</a>
            ) : (
              <span class="text-neutral-400 text-xs font-medium">{b.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <!-- Label pill -->
    <div class="mb-4 fade-up" style="animation-delay:50ms">
      <span class="text-[10px] font-black uppercase tracking-[0.16em] px-3 py-1.5 inline-block"
            style={`color:${ac.bar};background:${ac.glow.replace('0.6','0.12')};border:1px solid ${ac.glow.replace('0.6','0.3')};border-radius:2px`}>
        {label}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl md:text-5xl lg:text-[3.5rem] font-black text-white tracking-tight leading-[1.02] max-w-3xl fade-up"
        style="animation-delay:100ms">
      {title}
    </h1>

    <!-- Desc -->
    {desc && (
      <p class="text-neutral-400 text-sm leading-relaxed mt-4 max-w-xl fade-up" style="animation-delay:160ms">
        {desc}
      </p>
    )}
  </div>

  <!-- Sub-nav tabs -->
  {tabs.length > 0 && (
    <div class="relative border-t" style="border-color:rgba(255,255,255,0.07); z-index:3">
      <div class="max-w-screen-xl mx-auto px-8 md:px-14 flex gap-0 overflow-x-auto page-tabs">
        {tabs.map(tab => {
          // Normalise: apply url() only if href doesn't already carry the base prefix
          const basePath = base.replace(/\/$/, '');
          const tabUrl = (tab.href.startsWith('/') && basePath && !tab.href.startsWith(basePath + '/') && tab.href !== basePath)
            ? url(tab.href)
            : tab.href;
          const isActive = currentPath === tabUrl || currentPath.startsWith(tabUrl + '/');
          return (
            <a
              href={tabUrl}
              class:list={['page-tab', isActive ? 'page-tab-active' : '']}
              style={isActive ? `--tab-color:${ac.tabActive}` : ''}
            >
              {tab.label}
            </a>
          );
        })}
      </div>
    </div>
  )}
</div>

<style>
  .page-tab {
    display: inline-block;
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    color: rgba(255,255,255,0.45);
    transition: color 0.15s, border-color 0.15s;
  }
  .page-tab:hover { color: rgba(255,255,255,0.85); }
  .page-tab-active {
    color: var(--tab-color, var(--brand));
    border-bottom-color: var(--tab-color, var(--brand));
  }
</style>

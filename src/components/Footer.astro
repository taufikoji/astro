---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;

const socials = [
  {
    label: 'Instagram',
    href: 'https://instagram.com/stmktrisakti',
    abbr: 'IG',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    label: 'YouTube',
    href: 'https://youtube.com/stmktrisakti',
    abbr: 'YT',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="4"/><polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    label: 'Facebook',
    href: 'https://facebook.com/stmktrisakti',
    abbr: 'FB',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
  },
  {
    label: 'TikTok',
    href: 'https://tiktok.com/@stmktrisakti',
    abbr: 'TK',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.04a8.17 8.17 0 004.78 1.52V7.11a4.85 4.85 0 01-1.01-.42z"/></svg>`,
  },
];

const footerLinks = [
  {
    title: 'Program Studi',
    links: [
      { label: 'Desain Komunikasi Visual', href: url('/program/dkv') },
      { label: 'Teknologi Grafika',        href: url('/program/teknologi-grafika') },
      { label: 'Dosen Pengajar',           href: url('/program/dosen') },
      { label: 'Kurikulum & CPL',          href: url('/program') },
    ],
  },
  {
    title: 'Akademik',
    links: [
      { label: 'Penjaminan Mutu',   href: url('/akademik/penjaminan-mutu') },
      { label: 'Penelitian & PKM',  href: url('/akademik/penelitian') },
      { label: 'Panduan Akademik',  href: url('/akademik/panduan') },
      { label: 'Report Hub',        href: url('/akademik/report-hub') },
      { label: 'Jurnal Ilmiah',     href: url('/jurnal') },
    ],
  },
  {
    title: 'Institusi',
    links: [
      { label: 'Profil & Sejarah',       href: url('/tentang') },
      { label: 'Sambutan Ketua',         href: url('/tentang/sambutan-ketua') },
      { label: 'Visi & Misi',            href: url('/tentang/visi-misi') },
      { label: 'Akreditasi BAN-PT',      href: url('/akreditasi') },
      { label: 'Struktur Organisasi',    href: url('/tentang/struktur-organisasi') },
    ],
  },
  {
    title: 'Mahasiswa & Alumni',
    links: [
      { label: 'PMB 2026/2027',  href: url('/pmb') },
      { label: 'Fasilitas',      href: url('/fasilitas') },
      { label: 'Job Vacancy',    href: url('/karir-alumni/job-vacancy') },
      { label: 'Galeri Karya',   href: url('/galeri') },
      { label: 'Berita & Artikel', href: url('/berita') },
    ],
  },
];
---

<footer style="background:#07060F; border-top:1px solid rgba(255,255,255,0.05)">

  <!-- PMB strip -->
  <div class="relative overflow-hidden" style="background:var(--brand); border-bottom:1px solid rgba(0,0,0,0.2)">
    <div class="absolute inset-0 hero-grid opacity-20 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-screen-xl mx-auto px-8 md:px-14 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>
        <p class="text-white font-black text-base md:text-lg tracking-tight">
          Penerimaan Mahasiswa Baru 2026/2027 Sedang Berlangsung
        </p>
        <p class="text-white/60 text-xs mt-0.5">Beasiswa KIP-K, UTBK, dan YBT tersedia</p>
      </div>
      <div class="flex gap-3 shrink-0">
        <a href={url('/pmb')}
           class="text-sm font-black text-white bg-white/15 hover:bg-white/25 px-5 py-2.5 transition-colors"
           style="border:1px solid rgba(255,255,255,0.3);border-radius:2px">
          Daftar Online →
        </a>
        <a href="https://wa.me/6287742997808" target="_blank" rel="noopener noreferrer"
           class="text-sm font-black text-red-800 bg-white hover:bg-red-50 px-5 py-2.5 transition-colors"
           style="border-radius:2px">
          Chat WA
        </a>
      </div>
    </div>
  </div>

  <!-- Main footer body -->
  <div class="relative max-w-screen-xl mx-auto px-8 md:px-14 pt-16 pb-10">

    <!-- Subtle aurora glow in corner -->
    <div class="absolute pointer-events-none overflow-hidden inset-0" aria-hidden="true">
      <div class="aurora-blob opacity-20" style="width:500px;height:500px;bottom:-200px;right:-100px;background:radial-gradient(circle,rgba(200,16,46,0.4) 0%,transparent 60%);animation:aurora-3 25s ease-in-out infinite;"></div>
      <div class="aurora-blob opacity-15" style="width:400px;height:400px;top:-100px;left:-80px;background:radial-gradient(circle,rgba(200,80,255,0.3) 0%,transparent 60%);animation:aurora-2 30s ease-in-out infinite;"></div>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-12 gap-12 pb-12" style="border-bottom:1px solid rgba(255,255,255,0.06)">

      <!-- Brand column -->
      <div class="md:col-span-4">
        <a href={url('/')} class="flex items-center gap-3 mb-6">
          <img
            src={url('/images/logo-stmk.png')}
            alt="STMK Trisakti"
            class="h-10 w-auto object-contain"
            style="background:rgba(255,255,255,0.92);padding:4px 10px;border-radius:4px"
            loading="lazy"
          />
        </a>

        <p class="text-neutral-500 text-sm leading-relaxed mb-6 max-w-xs">
          Kampus desain & multimedia terdepan di Jakarta. Mendidik generasi kreatif yang kompetitif sejak 1999.
        </p>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-3 mb-8">
          {[
            { n: '32+', l: 'Tahun', c: 'var(--neon-red)' },
            { n: '2',   l: 'Prodi', c: 'var(--neon-cyan)' },
            { n: '95%', l: 'Serapan', c: 'var(--neon-green)' },
          ].map(s => (
            <div class="text-center py-3 px-2" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:3px">
              <div class="font-black text-lg leading-none mb-0.5" style={`color:${s.c}`}>{s.n}</div>
              <div class="text-[9px] uppercase tracking-widest text-neutral-600 font-bold">{s.l}</div>
            </div>
          ))}
        </div>

        <!-- Contact -->
        <div class="space-y-1.5 text-xs text-neutral-600 mb-6">
          <p class="leading-relaxed">Jl. Jend. Achmad Yani 85, Rawasari<br/>Jakarta Timur, DKI Jakarta</p>
          <a href="https://wa.me/6287742997808" class="block hover:text-white transition-colors">+62 877 4299 7808</a>
          <a href="tel:+622148957870" class="block hover:text-white transition-colors">+62 21 4895787</a>
          <a href="mailto:info@trisaktimultimedia.ac.id" class="block hover:text-white transition-colors">info@trisaktimultimedia.ac.id</a>
        </div>

        <!-- Social icons -->
        <div class="flex gap-2.5">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
               class="social-icon w-9 h-9 flex items-center justify-center transition-all duration-200"
               style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:3px;color:rgba(255,255,255,0.45)">
              <span class="w-4 h-4 block">
                <Fragment set:html={s.icon} />
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div class="md:col-span-8 grid grid-cols-2 md:grid-cols-4 gap-8">
        {footerLinks.map(col => (
          <div>
            <h4 class="text-white text-[10px] font-black uppercase tracking-[0.14em] mb-4 flex items-center gap-2">
              <span class="w-4 h-[2px] inline-block rounded-full" style="background:var(--brand)"></span>
              {col.title}
            </h4>
            <ul class="space-y-2.5">
              {col.links.map(l => (
                <li>
                  <a href={l.href}
                     class="text-neutral-600 hover:text-white text-xs transition-colors leading-snug block hover:translate-x-0.5 transition-transform">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom row -->
    <div class="relative pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
      <span class="text-[11px] text-neutral-700">
        &copy; {year} Sekolah Tinggi Media Komunikasi Trisakti. Hak Cipta Dilindungi.
      </span>
      <div class="flex items-center gap-4 text-[11px]">
        <span class="flex items-center gap-1.5 font-semibold" style="color:var(--neon-green)">
          <span class="w-1.5 h-1.5 rounded-full inline-block" style="background:var(--neon-green);box-shadow:0 0 6px var(--neon-green)"></span>
          Terakreditasi BAN-PT
        </span>
        <span class="text-neutral-800">·</span>
        <a href={url('/kebijakan-privasi')} class="text-neutral-600 hover:text-white transition-colors">Privasi</a>
        <a href={url('/syarat-ketentuan')} class="text-neutral-600 hover:text-white transition-colors">Syarat</a>
      </div>
    </div>
  </div>

  <!-- Mandatory logo strip -->
  <div style="background:rgba(255,255,255,0.03);border-top:1px solid rgba(255,255,255,0.05)">
    <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <img
        src={url('/images/logo-stmk.png')}
        alt="Trisakti School of Multimedia — DiktiSaintek Berdampak"
        class="h-10 w-auto object-contain"
        style="background:rgba(255,255,255,0.88);padding:4px 10px;border-radius:4px;opacity:0.85"
        loading="lazy"
      />
      <p class="text-[10px] text-neutral-700 text-center sm:text-right leading-relaxed">
        Terakreditasi oleh Badan Akreditasi Nasional Perguruan Tinggi (BAN-PT)<br/>
        Di bawah naungan Yayasan Trisakti · Kemendikbudristek RI
      </p>
    </div>
  </div>
</footer>

<style>
  .social-icon:hover {
    background: rgba(200,16,46,0.15) !important;
    border-color: rgba(200,16,46,0.4) !important;
    color: var(--neon-red) !important;
    box-shadow: 0 0 12px rgba(200,16,46,0.25);
  }
</style>

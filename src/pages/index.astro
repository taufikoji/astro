---
import Layout from '../layouts/Layout.astro';
import HalftoneCanvas from '../components/HalftoneCanvas.astro';
import ParticleField from '../components/ParticleField.astro';
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;

const programs = [
  {
    num: '01',
    title: 'Desain Komunikasi Visual',
    degree: 'S1 · Sarjana Desain',
    href: '/program/dkv',
    tracks: ['Animasi dan Games', 'Multimedia Penyiaran', 'Multimedia Periklanan', 'Desain Produk Kemasan'],
    desc: 'Kuasai storytelling visual — dari konsep hingga eksekusi. Program S1 berbasis industri bersama praktisi desain terkemuka.',
    color: 'var(--neon-purple)',
    glow: 'rgba(200,80,255,0.2)',
  },
  {
    num: '02',
    title: 'Teknologi Grafika',
    degree: 'D4 · Sarjana Terapan',
    href: '/program/teknologi-grafika',
    tracks: ['Desain Kemasan', 'Teknologi Cetak', 'Pre-press Digital', 'Produksi Grafika'],
    desc: 'Padukan keahlian desain dengan teknologi produksi grafika modern. Siap kerja sejak hari pertama.',
    color: 'var(--neon-cyan)',
    glow: 'rgba(0,229,255,0.2)',
  },
];

const tracks = [
  {
    id: 'animasi',
    title: 'Animasi & Games',
    desc: 'Hidupkan karakter, bangun dunia, ciptakan game. Dari 2D frame-by-frame hingga pipeline animasi 3D profesional.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="10,8 38,8 42,24 38,40 10,40 6,24"/><circle cx="24" cy="24" r="6"/><path d="M24 18v-6M24 36v-6M18 24h-6M36 24h-6"/></svg>`,
    color: '#C850FF', glow: 'rgba(200,80,255,0.5)',
    badge: 'DKV · Konsentrasi',
    pill: 'badge-neon-purple',
    bg: 'radial-gradient(ellipse at 30% 30%, rgba(200,80,255,0.25) 0%, transparent 70%), #0D0A14',
  },
  {
    id: 'broadcasting',
    title: 'Multimedia Penyiaran',
    desc: 'Produksi konten digital & broadcast — dari studio podcast hingga live streaming & video kreatif.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="8"/><path d="M12 12 Q24 4 36 12"/><path d="M8 8 Q24 0 40 8"/><path d="M12 36 Q24 44 36 36"/><path d="M8 40 Q24 48 40 40"/></svg>`,
    color: '#00E5FF', glow: 'rgba(0,229,255,0.5)',
    badge: 'DKV · Konsentrasi',
    pill: 'badge-neon-cyan',
    bg: 'radial-gradient(ellipse at 70% 30%, rgba(0,229,255,0.2) 0%, transparent 70%), #090E14',
  },
  {
    id: 'periklanan',
    title: 'Multimedia Periklanan',
    desc: 'Rancang kampanye kreatif multi-platform yang menggerakkan audiens — dari brief ke karya jadi.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="14" width="36" height="22" rx="2"/><path d="M14 14V10a2 2 0 012-2h16a2 2 0 012 2v4"/><path d="M18 28l4-4 4 4 6-8"/><circle cx="16" cy="28" r="2"/></svg>`,
    color: '#FFAB00', glow: 'rgba(255,171,0,0.5)',
    badge: 'DKV · Konsentrasi',
    pill: 'badge-neon-amber',
    bg: 'radial-gradient(ellipse at 50% 70%, rgba(255,171,0,0.2) 0%, transparent 70%), #100E06',
  },
  {
    id: 'kemasan',
    title: 'Desain Produk Kemasan',
    desc: 'Desain packaging yang memenangkan pasar — struktur, material, visual, dan strategi branding.',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M24 6L42 16v16L24 42 6 32V16z"/><path d="M24 6v36M6 16l18 10 18-10"/><path d="M15 11l18 10M33 11L15 21"/></svg>`,
    color: '#00E676', glow: 'rgba(0,230,118,0.5)',
    badge: 'DKV · Konsentrasi',
    pill: 'badge-neon-green',
    bg: 'radial-gradient(ellipse at 30% 70%, rgba(0,230,118,0.18) 0%, transparent 70%), #060E0A',
  },
];

const stats = [
  { num: '32+',    label: 'Tahun Pengalaman', color: 'var(--neon-red)' },
  { num: 'BAN-PT', label: 'Akreditasi Baik Sekali', color: 'var(--neon-cyan)' },
  { num: '2',      label: 'Program Studi Unggulan', color: 'var(--neon-purple)' },
  { num: '95%',    label: 'Serapan Kerja Alumni', color: 'var(--neon-amber)' },
];

const videos = [
  { id: '', title: 'Showreel Mahasiswa DKV — Animasi & Motion Graphics', category: 'Animasi', featured: true },
  { id: '', title: 'Packaging Design — Karya Tugas Akhir Teknologi Grafika', category: 'Teknologi Grafika', featured: false },
  { id: '', title: 'Kampanye Sosial — Tugas Akhir DKV Multimedia Periklanan', category: 'Periklanan', featured: false },
  { id: '', title: 'Broadcasting Multimedia — Produksi Program TV Mahasiswa', category: 'Broadcasting', featured: false },
];

const news = [
  { date: '15 Mei 2026', category: 'Prestasi',  title: 'STMK Trisakti Raih Penghargaan Kampus Inovatif 2025',                   href: '/berita/penghargaan-kampus-inovatif-2025' },
  { date: '10 Mei 2026', category: 'Kerjasama', title: 'MoU Bersama Studio Animasi Internasional untuk Program Magang',          href: '/berita/mou-studio-animasi-internasional' },
  { date: '5 Mei 2026',  category: 'Prestasi',  title: 'Mahasiswa Teknologi Grafika Juara 1 Lomba Packaging Nasional',           href: '/berita/juara-packaging-nasional' },
  { date: '2 Mei 2026',  category: 'Kegiatan',  title: 'Workshop Adobe After Effects Bersama Motion Designer Internasional',     href: '/berita/workshop-after-effects' },
];

const partners = [
  'Starbucks Indonesia', 'Damai Indah Golf', 'Dillco Group', 'ELEMGE',
  'PT Okho Tri Teknologi', 'Putra Putri Budaya Banten', 'SCG Indonesia',
  'Ruang Guru', 'Suara.com', 'Rara & Nusa',
];

const whyList = [
  { num: '70%',  title: 'Dosen dari Industri', desc: 'Tujuh dari sepuluh dosen adalah profesional aktif — art director, animator, packaging designer — yang masih berkarya di perusahaan terkemuka.', color: 'var(--neon-purple)' },
  { num: '95%',  title: 'Serapan Kerja < 6 Bulan', desc: 'Berdasarkan Tracer Study 2024, 95% lulusan STMK Trisakti sudah bekerja di bidangnya dalam 6 bulan setelah wisuda.', color: 'var(--neon-cyan)' },
  { num: '144',  title: 'SKS Berbasis Praktik', desc: 'Kurikulum OBE dirancang bersama mitra industri. Lebih dari 60% waktu belajar dihabiskan untuk praktik nyata dan proyek klien.', color: 'var(--neon-amber)' },
  { num: '30+',  title: 'MoU Aktif', desc: 'Kerjasama aktif dengan 30+ perusahaan dan institusi untuk magang, rekrutmen, dan proyek kolaborasi mahasiswa.', color: 'var(--neon-green)' },
];
---

<Layout
  title="Beranda"
  description="Trisakti School of Multimedia — Kampus Desain & Multimedia terdepan di Jakarta. Program S1 Desain Komunikasi Visual dan D4 Teknologi Grafika, terakreditasi BAN-PT Baik Sekali."
  darkNav={true}
>

<!-- ══════════════════════════════════════════════════
  §1  HERO — Aurora animated dark
══════════════════════════════════════════════════ -->
<section class="relative flex flex-col overflow-hidden scanlines noise" style="min-height:calc(100vh - 60px); background:#09090E;">

  <!-- Aurora blobs — more vivid -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="aurora-blob" style="width:800px;height:800px;top:-200px;left:-180px;background:radial-gradient(circle,rgba(200,16,46,0.6) 0%,transparent 62%);animation:aurora-1 16s ease-in-out infinite;"></div>
    <div class="aurora-blob" style="width:700px;height:700px;top:-100px;right:-140px;background:radial-gradient(circle,rgba(200,80,255,0.5) 0%,transparent 62%);animation:aurora-2 20s ease-in-out infinite;"></div>
    <div class="aurora-blob" style="width:600px;height:600px;bottom:-80px;left:25%;background:radial-gradient(circle,rgba(0,229,255,0.35) 0%,transparent 62%);animation:aurora-3 18s ease-in-out infinite;"></div>
    <div class="aurora-blob" style="width:450px;height:450px;bottom:60px;right:12%;background:radial-gradient(circle,rgba(255,171,0,0.25) 0%,transparent 62%);animation:aurora-4 22s ease-in-out infinite;"></div>
    <div class="aurora-blob" style="width:350px;height:350px;top:40%;left:40%;background:radial-gradient(circle,rgba(0,229,255,0.18) 0%,transparent 65%);animation:aurora-2 28s ease-in-out infinite reverse;"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 hero-grid" aria-hidden="true"></div>

  <!-- Scan line sweep (repeating) -->
  <div class="scan-line-sweep" aria-hidden="true"></div>

  <!-- Red brand bar left edge -->
  <div class="absolute top-0 left-0 bottom-0 w-[3px] z-10" style="background:var(--brand);" aria-hidden="true"></div>

  <!-- Particle field -->
  <ParticleField id="hero-particles" count={55} opacity={0.55} speed={0.35} />

  <!-- Halftone overlay -->
  <HalftoneCanvas id="hero-ht" opacity={0.28} spacing={28} speed={0.25} maxSize={0.45} color="white" color2="#C850FF" />

  <!-- Floating geometric decorations -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" style="z-index:3" aria-hidden="true">
    <!-- Triangle -->
    <div class="absolute float-1 opacity-25" style="top:12%;right:8%">
      <svg width="90" height="90" viewBox="0 0 90 90"><polygon points="45,6 84,78 6,78" fill="none" stroke="var(--neon-cyan)" stroke-width="1.5"/></svg>
    </div>
    <!-- Circle -->
    <div class="absolute float-2 opacity-20" style="top:55%;right:22%">
      <svg width="70" height="70" viewBox="0 0 70 70"><circle cx="35" cy="35" r="32" fill="none" stroke="var(--neon-purple)" stroke-width="1.5"/><circle cx="35" cy="35" r="20" fill="none" stroke="var(--neon-purple)" stroke-width="0.8" stroke-dasharray="4 4"/></svg>
    </div>
    <!-- Diamond -->
    <div class="absolute float-3 opacity-15" style="top:25%;right:42%">
      <svg width="55" height="55" viewBox="0 0 55 55"><rect x="8" y="8" width="39" height="39" fill="none" stroke="var(--neon-amber)" stroke-width="1.5" transform="rotate(45 27.5 27.5)"/></svg>
    </div>
    <!-- Hexagon -->
    <div class="absolute float-4 opacity-15" style="bottom:25%;right:6%">
      <svg width="65" height="65" viewBox="0 0 65 65"><polygon points="32.5,4 60,19 60,46 32.5,61 5,46 5,19" fill="none" stroke="var(--brand)" stroke-width="1.5"/></svg>
    </div>
    <!-- Dots cluster -->
    <div class="absolute float-5 opacity-25" style="bottom:35%;left:6%">
      <svg width="80" height="80" viewBox="0 0 80 80">
        <circle cx="10" cy="40" r="3" fill="var(--neon-cyan)"/><circle cx="25" cy="25" r="2" fill="var(--neon-purple)"/>
        <circle cx="40" cy="10" r="3" fill="var(--neon-cyan)"/><circle cx="55" cy="25" r="2" fill="var(--neon-amber)"/>
        <circle cx="70" cy="40" r="3" fill="var(--neon-cyan)"/><circle cx="55" cy="55" r="2" fill="var(--neon-purple)"/>
        <circle cx="40" cy="70" r="3" fill="var(--neon-cyan)"/><circle cx="25" cy="55" r="2" fill="var(--neon-amber)"/>
      </svg>
    </div>
    <!-- Game controller icon -->
    <div class="absolute float-2 opacity-20" style="top:40%;left:3%">
      <svg width="72" height="72" viewBox="0 0 72 72" fill="none" stroke="var(--neon-purple)" stroke-width="1.5" stroke-linecap="round"><rect x="8" y="22" width="56" height="30" rx="15"/><path d="M24 30v8M20 34h8"/><circle cx="48" cy="30" r="2.5" fill="var(--neon-purple)" stroke="none"/><circle cx="56" cy="34" r="2.5" fill="var(--neon-purple)" stroke="none"/><circle cx="48" cy="38" r="2.5" fill="var(--neon-purple)" stroke="none"/><circle cx="40" cy="34" r="2.5" fill="var(--neon-purple)" stroke="none"/></svg>
    </div>
  </div>

  <!-- Main content -->
  <div class="relative flex-1 flex flex-col justify-between" style="z-index:5">
    <div class="flex-1 flex items-center">
      <div class="w-full max-w-screen-xl mx-auto px-8 md:px-14 py-16 md:py-20">

        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-block w-8 h-[2px]" style="background:var(--brand)"></span>
          <span class="text-[11px] font-bold uppercase tracking-[0.14em]" style="color:rgba(255,255,255,0.45)">
            Trisakti School of Multimedia · Jakarta · BAN-PT Baik Sekali
          </span>
        </div>

        <!-- Headline with glitch + glow effect -->
        <div class="mb-10">
          <h1 class="font-black tracking-tight leading-[0.88] select-none"
              style="font-size:clamp(3.2rem,9.5vw,8rem)">
            <span class="block text-white">DESAIN</span>
            <span class="block gradient-text-cool glitch-wrap" data-text="ANIMASI" style="font-size:clamp(3.2rem,9.5vw,8rem)">ANIMASI</span>
            <span class="block" style="color:var(--brand);text-shadow:var(--glow-red)">KARYA.</span>
          </h1>
        </div>

        <!-- Role ticker -->
        <div class="role-ticker-wrap mb-10" style="color:rgba(255,255,255,0.35)">
          <span style="color:rgba(255,255,255,0.2)">Jadilah</span>
          <svg class="w-3 h-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          <span id="role-ticker" class="ticker-word in" style="color:var(--neon-cyan)">Animator</span>
        </div>

        <!-- Sub + CTAs -->
        <div class="flex flex-col md:flex-row md:items-end gap-10 md:gap-20 max-w-4xl">
          <div class="md:max-w-xs">
            <p class="text-neutral-400 text-base leading-relaxed">
              Kampus desain dan multimedia terdepan di Jakarta. Kuasai seni visual, teknologi produksi, dan kreasi konten bersama praktisi industri kelas dunia.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 shrink-0">
            <a href={url('/pmb')} class="btn-primary pulse-red">
              Daftar 2026/2027
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a href={url('/program')} class="btn-outline-white">Lihat Program</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="relative border-t" style="border-color:rgba(255,255,255,0.06); background:rgba(9,9,14,0.8)">
      <div style="backdrop-filter:blur(12px)">
        <div class="max-w-screen-xl mx-auto px-8 md:px-14">
          <div class="grid grid-cols-2 md:grid-cols-4 divide-x" style="border-color:rgba(255,255,255,0.06)">
            {stats.map(s => (
              <div class="py-5 px-4 md:px-8 first:pl-0 last:pr-0 group">
                <div class="text-2xl md:text-3xl font-black tracking-tight transition-all duration-300"
                     style={`color:${s.color}`}>{s.num}</div>
                <div class="text-[10px] mt-1 uppercase tracking-widest text-neutral-600">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════════
  §2  MARQUEE — disciplines (neon style)
══════════════════════════════════════════════════ -->
<div class="overflow-hidden py-3 border-b border-neutral-900" style="background:#0D0B14">
  <div class="marquee-track whitespace-nowrap">
    {[...Array(2)].map(() =>
      [
        { t: 'Animasi 3D', c: 'var(--neon-purple)' },
        { t: 'Packaging Design', c: 'var(--neon-green)' },
        { t: 'UI/UX Design', c: 'var(--neon-cyan)' },
        { t: 'Game Development', c: 'var(--neon-purple)' },
        { t: 'Broadcasting', c: 'var(--neon-cyan)' },
        { t: 'Motion Graphics', c: 'var(--neon-amber)' },
        { t: 'Digital Printing', c: 'var(--neon-green)' },
        { t: 'Branding & Identitas', c: 'var(--neon-amber)' },
        { t: 'Ilustrasi Digital', c: 'var(--neon-purple)' },
        { t: 'VFX & Compositing', c: 'var(--neon-cyan)' },
        { t: 'Videografi', c: 'var(--neon-green)' },
        { t: 'Tipografi', c: 'var(--neon-amber)' },
      ].map(item => (
        <span class="inline-flex items-center gap-4 px-5 text-[11px] font-black uppercase tracking-[0.15em]"
              style={`color:${item.c};opacity:0.7`}>
          {item.t}<span class="opacity-30" style={`color:${item.c}`}>◆</span>
        </span>
      ))
    )}
  </div>
</div>


<!-- ══════════════════════════════════════════════════
  §3  PROGRAMS — glass cards
══════════════════════════════════════════════════ -->
<section class="py-24 relative overflow-hidden" style="background:#0D0B14">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="aurora-blob opacity-30" style="width:500px;height:500px;top:-100px;right:-100px;background:radial-gradient(circle,rgba(200,80,255,0.2) 0%,transparent 70%);animation:aurora-2 25s ease-in-out infinite;"></div>
  </div>

  <div class="relative max-w-screen-xl mx-auto px-8 md:px-14">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14 reveal">
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.14em] mb-4" style="color:rgba(255,255,255,0.35)">Program Studi</p>
        <h2 class="font-black tracking-tight text-white" style="font-size:clamp(2.5rem,5vw,4rem)">
          Dua Jalur.<br/>
          <span class="gradient-text-cool">Satu Tujuan.</span>
        </h2>
      </div>
      <a href={url('/program')} class="text-sm font-semibold text-neutral-600 hover:text-white transition-colors self-start md:self-end mb-2 flex items-center gap-2">
        Semua program <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      {programs.map((prog, i) => (
        <a href={url(prog.href)}
           class="card-neon tilt-card shimmer-hover group p-8 block reveal"
           style={`transition-delay:${i*100}ms`}>
          <!-- Number -->
          <div class="font-black text-7xl leading-none mb-6 select-none"
               style={`color:${prog.glow.replace('rgba','rgb').replace(',0.2)',')')};opacity:0.15;transition:opacity 0.3s`}
               data-glow-num>
            {prog.num}
          </div>
          <!-- Degree badge -->
          <div class="mb-4">
            <span class="text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 text-neutral-400"
                  style={`border:1px solid rgba(255,255,255,0.12);border-radius:2px`}>
              {prog.degree}
            </span>
          </div>
          <!-- Title -->
          <h3 class="text-2xl md:text-3xl font-black text-white tracking-tight mb-3 transition-colors duration-300"
              style={`transition:color 0.3s`}
              data-prog-title>
            {prog.title}
          </h3>
          <p class="text-sm text-neutral-500 leading-relaxed mb-6 max-w-sm">{prog.desc}</p>
          <!-- Track pills -->
          <div class="flex flex-wrap gap-2">
            {prog.tracks.map(t => (
              <span class="text-[11px] font-semibold px-3 py-1.5 tracking-wide"
                    style={`background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);border-radius:2px`}>
                {t}
              </span>
            ))}
          </div>
          <!-- Arrow -->
          <div class="mt-6 flex items-center gap-2 font-semibold text-sm transition-all duration-300"
               style={`color:${prog.color}`}>
            <span>Pelajari Program</span>
            <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ══════════════════════════════════════════════════
  §4  TRACKS SPOTLIGHT — 4 DKV concentration cards
══════════════════════════════════════════════════ -->
<section class="py-24 relative" style="background:#09090E">
  <div class="absolute inset-0 dot-grid opacity-40" aria-hidden="true"></div>

  <div class="relative max-w-screen-xl mx-auto px-8 md:px-14">
    <div class="text-center mb-16 reveal">
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] mb-4" style="color:rgba(255,255,255,0.35)">Konsentrasi DKV</p>
      <h2 class="font-black tracking-tight text-white mb-4" style="font-size:clamp(2rem,4.5vw,3.5rem)">
        Pilih <span class="gradient-text-fire">Bidangmu.</span>
      </h2>
      <p class="text-neutral-500 text-sm max-w-xl mx-auto leading-relaxed">
        Empat konsentrasi unggulan yang dirancang bersama industri kreatif — masing-masing membuka jalan karir yang berbeda.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 stagger">
      {tracks.map((track, i) => (
        <a href={url('/program/dkv')}
           class="track-card shimmer-hover group block p-8"
           style={`background:${track.bg};min-height:260px`}>
          <!-- Icon -->
          <div class="w-14 h-14 mb-6 transition-all duration-300 group-hover:scale-110"
               style={`color:${track.color};filter:drop-shadow(0 0 8px ${track.glow})`}>
            <Fragment set:html={track.icon} />
          </div>
          <!-- Badge -->
          <div class="mb-3">
            <span class={`badge-neon-${track.pill.split('-').pop()} text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 ${track.pill}`}
                  style="border-radius:2px">
              {track.badge}

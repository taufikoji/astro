<script>
  /* ── 3D tilt on .tilt-card ── */
  document.querySelectorAll<HTMLElement>('.tilt-card').forEach(card => {
    let raf = 0;
    card.addEventListener('mousemove', (e: MouseEvent) => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(900px) rotateX(${-y * 8}deg) rotateY(${x * 8}deg) scale(1.015)`;
        card.style.transition = 'transform 0.08s ease-out';
        const numEl = card.querySelector<HTMLElement>('[data-glow-num]');
        if (numEl) numEl.style.opacity = '0.35';
        const titleEl = card.querySelector<HTMLElement>('[data-prog-title]');
        if (titleEl) titleEl.style.color = 'white';
      });
    });
    card.addEventListener('mouseleave', () => {
      cancelAnimationFrame(raf);
      card.style.transform = 'perspective(900px) rotateX(0) rotateY(0) scale(1)';
      card.style.transition = 'transform 0.5s cubic-bezier(0.23,1,0.32,1)';
      const numEl = card.querySelector<HTMLElement>('[data-glow-num]');
      if (numEl) numEl.style.opacity = '0.15';
      const titleEl = card.querySelector<HTMLElement>('[data-prog-title]');
      if (titleEl) titleEl.style.color = 'white';
    });
  });

  /* ── Role ticker ── */
  (function () {
    const roles = [
      { label: 'Animator',          color: 'var(--neon-purple)' },
      { label: 'Game Designer',     color: 'var(--neon-cyan)' },
      { label: 'Art Director',      color: 'var(--neon-amber)' },
      { label: 'Motion Designer',   color: 'var(--neon-green)' },
      { label: 'Packaging Designer',color: 'var(--neon-red)' },
      { label: 'Brand Strategist',  color: 'var(--neon-cyan)' },
    ];
    let idx = 0;
    const el = document.getElementById('role-ticker') as HTMLElement | null;
    if (!el) return;

    setInterval(() => {
      /* exit animation */
      el.classList.remove('in');
      el.classList.add('out');
      setTimeout(() => {
        idx = (idx + 1) % roles.length;
        el.textContent = roles[idx].label;
        el.style.color  = roles[idx].color;
        el.classList.remove('out');
        el.classList.add('in');
      }, 270);
    }, 2600);
  })();

  /* ── Text scramble on ANIMASI headline ── */
  (function () {
    const maybeTarget = document.querySelector<HTMLElement>('.glitch-wrap[data-text="ANIMASI"]');
    if (!maybeTarget) return;
    const target: HTMLElement = maybeTarget;
    const chars = '!@#$%^&*+=/\\|?◆※△▲●◉✦★';
    const original = 'ANIMASI';

    function scramble() {
      const letters = original.split('');
      let frame = 0;
      const total = 18;
      const id = setInterval(() => {
        const pct = frame / total;
        const resolved = Math.floor(pct * letters.length);
        let out = '';
        for (let i = 0; i < letters.length; i++) {
          if (i < resolved) {
            out += letters[i];
          } else {
            out += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        target.textContent = out;
        frame++;
        if (frame > total) clearInterval(id);
      }, 45);
    }

    /* Fire every ~5 seconds */
    setTimeout(scramble, 2000);
    setInterval(scramble, 5500);
  })();
</script>

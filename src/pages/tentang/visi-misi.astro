---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';

const tabs = [
  { label: 'Profil', href: '/tentang' },
  { label: 'Sambutan Ketua', href: '/tentang/sambutan-ketua' },
  { label: 'Visi & Misi', href: '/tentang/visi-misi' },
  { label: 'Sejarah', href: '/tentang/sejarah' },
  { label: 'Struktur Organisasi', href: '/tentang/struktur-organisasi' },
];

const misi = [
  {
    num: '01',
    title: 'Pendidikan, Penelitian & Pengabdian',
    desc: 'Menyelenggarakan pendidikan, penelitian dan pengabdian kepada masyarakat yang bertumpu kepada kreatifitas, budaya, dan teknologi.',
  },
  {
    num: '02',
    title: 'Pengembangan & Penyebarluasan Ilmu',
    desc: 'Melakukan pengembangan dan penyebarluasan ilmu pengetahuan, seni, budaya, dan teknologi dalam upaya untuk meningkatkan taraf kehidupan masyarakat.',
  },
  {
    num: '03',
    title: 'Organisasi Sehat & Jaringan Kerjasama',
    desc: 'Membangun organisasi yang sehat, otonom dan mandiri, serta mengembangkan jaringan kerjasama dengan industri dan kemitraan yang berkelanjutan.',
  },
];

const sasaran = [
  { sasaran: 'Kualitas Lulusan', indikator: 'Tingkat serapan kerja dalam 6 bulan', target: '95%' },
  { sasaran: 'Akreditasi Program', indikator: 'Status akreditasi BAN-PT/LAMDIK', target: 'Unggul' },
  { sasaran: 'Publikasi Ilmiah', indikator: 'Jumlah artikel terindeks Scopus/SINTA', target: '50/tahun' },
  { sasaran: 'Kerjasama Industri', indikator: 'Jumlah MoU aktif', target: '200+' },
  { sasaran: 'Mahasiswa Aktif', indikator: 'Jumlah mahasiswa terdaftar', target: '3.000+' },
  { sasaran: 'Prestasi Mahasiswa', indikator: 'Penghargaan nasional/internasional per tahun', target: '30+' },
];
---

<Layout title="Visi & Misi" description="Visi, Misi, Tujuan dan Sasaran STMK Trisakti 2025–2030.">

  <PageHeader
    label="Profil Institusi"
    title="Visi, Misi & Tujuan"
    desc="Arah dan komitmen STMK Trisakti dalam mewujudkan pendidikan multimedia berkualitas dunia."
    breadcrumb={[{ label: 'Tentang', href: '/tentang' }, { label: 'Visi & Misi', href: '' }]}
    tabs={tabs}
    currentPath={Astro.url.pathname}
  />

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-20 space-y-20">

    <!-- VISI -->
    <div class="reveal">
      <p class="section-num mb-4">Visi</p>
      <div class="border-l-[3px] pl-8 py-2" style="border-color:var(--brand)">
        <blockquote class="text-2xl md:text-3xl font-black text-neutral-950 tracking-tight leading-snug max-w-3xl">
          "Menjadi perguruan tinggi media komunikasi yang berkualitas global dan pusat pengembangan kreatifitas, budaya dan teknologi"
        </blockquote>
        <p class="text-neutral-400 text-sm mt-4 font-semibold uppercase tracking-widest">Visi STMK Trisakti</p>
      </div>
    </div>

    <!-- MISI -->
    <div>
      <p class="section-num mb-4 reveal">Misi</p>
      <h2 class="text-3xl md:text-4xl font-black text-neutral-950 tracking-tight mb-2 reveal">Misi STMK Trisakti</h2>
      <p class="text-neutral-500 text-sm mb-10 reveal">Tiga misi utama yang memandu seluruh kegiatan akademik, penelitian, dan kemasyarakatan STMK Trisakti.</p>
      <div class="space-y-0 border-t border-neutral-200">
        {misi.map((m, i) => (
          <div class="flex gap-6 md:gap-10 py-8 border-b border-neutral-200 group
                      hover:bg-white hover:-mx-8 hover:px-8 md:hover:-mx-14 md:hover:px-14
                      transition-all reveal"
               style={`transition-delay:${i*60}ms`}>
            <span class="text-4xl font-black leading-none shrink-0 w-12 pt-1"
                  style="color:#e5e7eb;transition:color 0.2s">
              {m.num}
            </span>
            <div>
              <h3 class="font-black text-neutral-950 mb-2 text-lg group-hover:text-[var(--brand)] transition-colors">{m.title}</h3>
              <p class="text-sm text-neutral-500 leading-relaxed max-w-2xl">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- TUJUAN -->
    <div>
      <p class="section-num mb-4 reveal">Tujuan</p>
      <h2 class="text-3xl font-black text-neutral-950 tracking-tight mb-10 reveal">Tujuan Institusi</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200 stagger">
        {[
          { num: '1', title: 'Lulusan Kompetitif', desc: 'Menghasilkan lulusan yang kompeten dan kompetitif di bidang multimedia, desain komunikasi visual, dan teknologi grafika.' },
          { num: '2', title: 'Riset Berkualitas', desc: 'Menghasilkan karya penelitian dan publikasi ilmiah yang berkontribusi pada pengembangan ilmu pengetahuan multimedia.' },
          { num: '3', title: 'Pengabdian Bermakna', desc: 'Memberikan kontribusi nyata kepada masyarakat melalui program pengabdian yang menggunakan keahlian multimedia.' },
          { num: '4', title: 'Ekosistem Kolaborasi', desc: 'Membangun ekosistem kolaborasi yang kuat antara kampus, industri, pemerintah, dan komunitas kreatif.' },
          { num: '5', title: 'Pengakuan Internasional', desc: 'Mendapatkan pengakuan dan akreditasi terbaik di tingkat nasional dan internasional sebagai kampus multimedia unggulan.' },
          { num: '6', title: 'Wirausahawan Kreatif', desc: 'Melahirkan wirausahawan di bidang industri kreatif yang mampu menciptakan lapangan kerja dan mendorong ekonomi.' },
        ].map(t => (
          <div class="bg-[#FAFAF8] hover:bg-white p-8 group transition-colors">
            <div class="text-5xl font-black leading-none mb-4" style="color:#f0f0ee">{t.num}</div>
            <h3 class="font-black text-neutral-950 mb-2 group-hover:text-[var(--brand)] transition-colors">{t.title}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- SASARAN -->
    <div class="reveal">
      <p class="section-num mb-4">Sasaran Strategis</p>
      <h2 class="text-3xl font-black text-neutral-950 tracking-tight mb-8">Sasaran Strategis</h2>
      <div class="overflow-hidden border border-neutral-200" style="border-radius:2px">
        <table class="w-full table-pro">
          <thead>
            <tr>
              <th>Sasaran</th>
              <th>Indikator</th>
              <th>Target 2030</th>
            </tr>
          </thead>
          <tbody>
            {sasaran.map(row => (
              <tr class="group hover:bg-red-50/30 transition-colors">
                <td class="font-semibold text-neutral-800">{row.sasaran}</td>
                <td>{row.indikator}</td>
                <td>
                  <span class="badge badge-green">{row.target}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

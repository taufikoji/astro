---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const jurnal = [
  {
    nama: 'JIKOMTI',
    kepanjangan: 'Jurnal Ilmu Komunikasi dan Teknologi Informasi',
    issn: '2355-4223',
    issnOnline: '2716-3946',
    frekuensi: '2 kali setahun (Maret & September)',
    fokus: 'Ilmu komunikasi, media digital, teknologi informasi, dan jurnalistik multimedia.',
    prodi: 'DKV',
    warna: 'from-blue-600 to-blue-800',
    link: '#',
  },
  {
    nama: 'GRAFIKA',
    kepanjangan: 'Jurnal Ilmu Teknologi Grafika',
    issn: '2355-4231',
    issnOnline: '2716-3954',
    frekuensi: '2 kali setahun (April & Oktober)',
    fokus: 'Teknologi percetakan, kemasan, material grafika, proses produksi grafis, dan desain kemasan.',
    prodi: 'Teknologi Grafika',
    warna: 'from-orange-500 to-orange-700',
    link: '#',
  },
];

const edisi = [
  { jurnal: 'JIKOMTI', vol: 'Vol. 10, No. 2', tahun: '2024', tema: 'AI dalam Industri Kreatif', artikel: 8 },
  { jurnal: 'GRAFIKA', vol: 'Vol. 8, No. 1', tahun: '2024', tema: 'Inovasi Desain Kemasan Berkelanjutan', artikel: 7 },
  { jurnal: 'JIKOMTI', vol: 'Vol. 10, No. 1', tahun: '2024', tema: 'Media Sosial dan Branding Digital', artikel: 9 },
  { jurnal: 'GRAFIKA', vol: 'Vol. 7, No. 2', tahun: '2023', tema: 'Smart Packaging Technology', artikel: 6 },
  { jurnal: 'JIKOMTI', vol: 'Vol. 9, No. 2', tahun: '2023', tema: 'Animasi dan Hiburan Digital', artikel: 8 },
  { jurnal: 'GRAFIKA', vol: 'Vol. 7, No. 1', tahun: '2023', tema: 'Green Printing & Sustainability', artikel: 7 },
];

const panduan = [
  { no: '1', judul: 'Persiapkan Naskah', desc: 'Tulis artikel sesuai template yang tersedia. Panjang artikel 4.000–8.000 kata dengan abstrak Bahasa Indonesia dan Inggris.' },
  { no: '2', judul: 'Submit Online', desc: 'Kirimkan naskah melalui sistem OJS (Open Journal System) atau email redaksi jurnal terkait.' },
  { no: '3', judul: 'Review & Revisi', desc: 'Naskah akan melalui proses double-blind review oleh 2 reviewer ahli. Penulis wajib merevisi sesuai catatan reviewer.' },
  { no: '4', judul: 'Publikasi', desc: 'Artikel yang lolos review akan diterbitkan pada edisi berikutnya sesuai jadwal publikasi jurnal.' },
];
---

<Layout title="Jurnal STMK Trisakti" description="Jurnal ilmiah STMK Trisakti — JIKOMTI dan GRAFIKA, publikasi penelitian bidang komunikasi, desain, dan teknologi grafika.">

  <PageHeader
    label="Publikasi Akademik"
    title="Jurnal"
    desc="Publikasi ilmiah STMK Trisakti yang menampung hasil penelitian dosen, mahasiswa, dan akademisi di bidang multimedia."
    breadcrumb={[{ label: 'Jurnal', href: '' }]}
    currentPath={Astro.url.pathname}
  />

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-20">

    <!-- Jurnal cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20 reveal">
      {jurnal.map((j, i) => (
        <div class="rounded-3xl overflow-hidden border border-neutral-100 card-hover reveal" style={`transition-delay:${i*80}ms`}>
          <div class={`bg-gradient-to-br ${j.warna} p-8`}>
            <p class="text-white/60 text-xs font-semibold uppercase tracking-widest mb-2">{j.prodi}</p>
            <h2 class="text-3xl font-black text-white mb-1">{j.nama}</h2>
            <p class="text-white/80 text-sm">{j.kepanjangan}</p>
          </div>
          <div class="bg-white p-8">
            <p class="text-neutral-500 text-sm leading-relaxed mb-6">{j.fokus}</p>
            <div class="grid grid-cols-2 gap-4 mb-6">
              <div>
                <p class="text-xs text-neutral-400 mb-0.5">ISSN Cetak</p>
                <p class="font-black text-neutral-950 text-sm">{j.issn}</p>
              </div>
              <div>
                <p class="text-xs text-neutral-400 mb-0.5">ISSN Online</p>
                <p class="font-black text-neutral-950 text-sm">{j.issnOnline}</p>
              </div>
              <div class="col-span-2">
                <p class="text-xs text-neutral-400 mb-0.5">Frekuensi Terbit</p>
                <p class="font-semibold text-neutral-700 text-sm">{j.frekuensi}</p>
              </div>
            </div>
            <a
              href={j.link}
              class="text-sm font-black flex items-center gap-2 transition-colors hover:opacity-70"
              style="color:var(--brand)"
            >
              Buka Portal Jurnal
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Edisi Terbaru -->
    <div class="mb-20 reveal">
      <p class="section-num mb-3">Terbitan Terkini</p>
      <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Edisi Terbaru</h2>
      <div class="space-y-0 border-t border-neutral-100">
        {edisi.map((e, i) => (
          <div class="grid grid-cols-12 gap-4 py-5 border-b border-neutral-100 hover:bg-neutral-50 -mx-3 px-3 rounded-xl transition-colors reveal" style={`transition-delay:${i*40}ms`}>
            <div class="col-span-2 md:col-span-1">
              <span class={`text-xs px-2.5 py-1 rounded-full font-semibold ${e.jurnal === 'JIKOMTI' ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700'}`}>
                {e.jurnal}
              </span>
            </div>
            <div class="col-span-10 md:col-span-11 flex flex-col md:flex-row md:items-center md:justify-between gap-2">
              <div>
                <h3 class="font-black text-neutral-950 text-sm">{e.tema}</h3>
                <p class="text-xs text-neutral-400">{e.vol} · {e.tahun} · {e.artikel} Artikel</p>
              </div>
              <a href="#" class="text-xs font-semibold text-neutral-400 hover:text-neutral-700 transition-colors shrink-0">
                Unduh PDF →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Panduan Submit -->
    <div class="mb-20 reveal">
      <p class="section-num mb-3">Bagi Penulis</p>
      <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Cara Submit Artikel</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {panduan.map((p, i) => (
          <div class="reveal" style={`transition-delay:${i*60}ms`}>
            <div class="text-5xl font-black mb-4 opacity-10" style="color:var(--brand)">{p.no}</div>
            <h3 class="font-black text-neutral-950 text-sm mb-2">{p.judul}</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal">
      <div class="rounded-2xl border border-neutral-200 p-8">
        <div class="text-3xl mb-4">📄</div>
        <h3 class="font-black text-neutral-950 text-lg mb-2">Download Template</h3>
        <p class="text-neutral-500 text-sm leading-relaxed mb-5">
          Unduh template penulisan artikel untuk JIKOMTI dan GRAFIKA dalam format Microsoft Word.
        </p>
        <div class="flex gap-3">
          <a href="#" class="text-xs font-black px-4 py-2 rounded-xl text-white" style="background:var(--brand)">Template JIKOMTI</a>
          <a href="#" class="text-xs font-black px-4 py-2 rounded-xl text-white bg-orange-500">Template GRAFIKA</a>
        </div>
      </div>
      <div class="rounded-2xl p-8 text-white" style="background:var(--brand)">
        <div class="text-3xl mb-4">✉️</div>
        <h3 class="font-black text-xl mb-2">Hubungi Redaksi</h3>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          Punya pertanyaan seputar proses pengiriman naskah atau ingin bergabung sebagai reviewer? Hubungi tim redaksi kami.
        </p>
        <a href="mailto:jurnal@trisaktimultimedia.ac.id" class="inline-block bg-white font-black text-blue-900 text-sm px-5 py-2.5 rounded-xl hover:bg-blue-50 transition-colors">
          jurnal@trisaktimultimedia.ac.id
        </a>
      </div>
    </div>

  </div>
</Layout>

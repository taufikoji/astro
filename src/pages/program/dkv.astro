---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';

const dosen = [
  { nama: 'xxxxxxxxx', keahlian: 'Desain Komunikasi Visual, Identitas Merek', nidn: '0301018501' },
  { nama: 'xxxxxxxxx', keahlian: 'Animasi 3D, Motion Graphics', nidn: '0415077802' },
  { nama: 'xxxxxxxxx', keahlian: 'Ilustrasi Digital, Tipografi', nidn: '0623068903' },
  { nama: 'xxxxxxxxx', keahlian: 'UI/UX Design, Interaction Design', nidn: '0901099001' },
  { nama: 'xxxxxxxxx', keahlian: 'Teori Desain, Estetika Visual', nidn: '0512106502' },
  { nama: 'xxxxxxxxx', keahlian: 'Fotografi Komersial, Videografi', nidn: '0730079401' },
];

const kurikulum = [
  { sem: 1, matkul: ['Nirmana Dwimatra', 'Tipografi Dasar', 'Gambar Bentuk', 'Komputer Grafis I', 'Bahasa Indonesia', 'Agama & Etika', 'Pancasila'] },
  { sem: 2, matkul: ['Nirmana Trimatra', 'Tipografi Terapan', 'Ilustrasi Digital', 'Komputer Grafis II', 'Bahasa Inggris I', 'Kewarganegaraan', 'Fotografi Dasar'] },
  { sem: 3, matkul: ['Desain Identitas Visual', 'Desain Editorial', 'Fotografi Komersial', 'Animasi 2D Dasar', 'Bahasa Inggris II', 'Metode Riset Desain', 'Psikologi Komunikasi'] },
  { sem: 4, matkul: ['Desain Periklanan', 'Motion Graphics', 'Animasi 3D Dasar', 'UI/UX Design I', 'Manajemen Desain', 'Etika Profesi', 'Metodologi Penelitian'] },
];

const cpl = [
  'Mampu menerapkan prinsip-prinsip desain komunikasi visual dalam berbagai media dan platform secara profesional.',
  'Mampu menganalisis permasalahan komunikasi visual dan merancang solusi desain yang inovatif dan efektif.',
  'Mampu mengoperasikan perangkat lunak desain industri (Adobe CC, Figma, Blender) secara profesional.',
  'Mampu berkolaborasi dalam tim multidisiplin dan mengkomunikasikan konsep desain kepada klien.',
  'Mampu mengembangkan portofolio profesional yang memenuhi standar industri kreatif.',
  'Memiliki sikap profesional, etis, dan bertanggung jawab dalam praktik desain komunikasi visual.',
];

const karir = ['Graphic Designer', 'Art Director', 'Animator 2D/3D', 'Motion Designer', 'UI/UX Designer', 'Illustrator', 'Creative Director', 'Brand Strategist', 'Content Creator', 'Visual Effects Artist', 'Game Designer', 'Creative Entrepreneur'];
---

<Layout title="Desain Komunikasi Visual (DKV)" description="Program S1 Desain Komunikasi Visual STMK Trisakti — terakreditasi Baik Sekali BAN-PT. Animasi, periklanan, UI/UX, dan ilustrasi digital.">

  <PageHeader
    label="Program Studi"
    title="Desain Komunikasi Visual"
    desc="S1 — Sarjana Desain · Gelar: S.Ds · Terakreditasi Baik Sekali BAN-PT"
    breadcrumb={[{ label: 'Program Studi', href: '/program' }, { label: 'DKV', href: '' }]}
  />

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Main content -->
      <div class="lg:col-span-2 space-y-14">

        <!-- Info pills -->
        <div class="flex flex-wrap gap-2 reveal stagger">
          {[
            { label: 'Jenjang', val: 'S1' },
            { label: 'Akreditasi', val: 'Baik Sekali' },
            { label: 'Total SKS', val: '144' },
            { label: 'Durasi', val: '4 Tahun' },
          ].map(i => (
            <div class="border border-neutral-200 bg-white px-5 py-3 text-center" style="border-radius:2px">
              <div class="text-xl font-black tracking-tight" style="color:var(--brand)">{i.val}</div>
              <div class="text-[10px] text-neutral-400 uppercase tracking-widest font-bold mt-0.5">{i.label}</div>
            </div>
          ))}
        </div>

        <!-- Deskripsi -->
        <div class="reveal">
          <p class="section-num mb-4">Tentang Program</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-5">Program S1 DKV STMK Trisakti</h2>
          <p class="text-sm text-neutral-600 leading-relaxed mb-4">Program Studi DKV STMK Trisakti adalah program S1 yang mengintegrasikan seni, desain, dan teknologi digital untuk menghasilkan komunikasi visual yang efektif dan berpengaruh. Dengan kurikulum berbasis OBE (Outcome-Based Education) yang diselaraskan dengan KKNI Level 6, mahasiswa DKV dipersiapkan untuk berkarir sebagai desainer profesional, art director, animator, hingga entrepreneur kreatif.</p>
        </div>

        <!-- Peminatan -->
        <div class="reveal">
          <p class="section-num mb-4">Peminatan</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Konsentrasi / Peminatan</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200 stagger">
            {[
              { title: 'Animasi', desc: 'Animasi 2D, 3D, motion graphics, dan visual effects untuk film, iklan, dan konten digital.' },
              { title: 'Periklanan', desc: 'Strategi kreatif iklan, kampanye digital, dan komunikasi merek untuk berbagai platform media.' },
              { title: 'Ilustrasi Digital', desc: 'Ilustrasi untuk buku, editorial, game, merchandise, dan konten media sosial.' },
              { title: 'UI/UX Design', desc: 'Desain antarmuka aplikasi mobile dan web yang berpusat pada pengalaman pengguna.' },
            ].map(p => (
              <div class="card-line bg-[#FAFAF8] hover:bg-white p-6 group">
                <h3 class="font-black text-neutral-950 mb-2 group-hover:text-[var(--brand)] transition-colors">{p.title}</h3>
                <p class="text-xs text-neutral-500 leading-relaxed">{p.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- CPL -->
        <div class="reveal">
          <p class="section-num mb-4">Kompetensi Lulusan</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Capaian Pembelajaran (CPL)</h2>
          <div class="space-y-3 stagger">
            {cpl.map((c, i) => (
              <div class="flex gap-3 items-start border-b border-neutral-100 pb-3 group hover:border-[var(--brand)] transition-colors">
                <span class="w-6 h-6 flex items-center justify-center text-white text-xs font-black shrink-0 mt-0.5"
                      style="background:var(--brand)">{i+1}</span>
                <p class="text-sm text-neutral-600 leading-relaxed">{c}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Kurikulum -->
        <div class="reveal">
          <p class="section-num mb-4">Kurikulum</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Struktur Kurikulum (4 Semester Pertama)</h2>
          <div class="space-y-2">
            {kurikulum.map(sem => (
              <details class="border border-neutral-200 bg-white overflow-hidden group" style="border-radius:2px">
                <summary class="px-5 py-4 font-bold text-sm cursor-pointer flex justify-between items-center hover:bg-neutral-50 transition-colors list-none">
                  <span>Semester {sem.sem}</span>
                  <svg class="w-4 h-4 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-5 pb-4 pt-2 flex flex-wrap gap-2 border-t border-neutral-100">
                  {sem.matkul.map(m => (
                    <span class="badge badge-gray text-[10px]">{m}</span>
                  ))}
                </div>
              </details>
            ))}
            <p class="text-xs text-neutral-400 text-center pt-2">
              <a href="/program/dkv/kurikulum" class="hover:text-[var(--brand)] transition-colors font-semibold">Lihat kurikulum lengkap 8 semester →</a>
            </p>
          </div>
        </div>

        <!-- Prospek Karir -->
        <div class="reveal">
          <p class="section-num mb-4">Karir</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Prospek Karir</h2>
          <div class="flex flex-wrap gap-2 stagger">
            {karir.map(k => (
              <div class="border border-neutral-200 bg-white hover:border-[var(--brand)] hover:text-[var(--brand)] text-neutral-600 text-xs font-semibold px-4 py-2.5 transition-all cursor-default">
                {k}
              </div>
            ))}
          </div>
        </div>

        <!-- Dosen -->
        <div class="reveal">
          <p class="section-num mb-4">Pengajar</p>
          <h2 class="text-2xl font-black text-neutral-950 tracking-tight mb-8">Dosen Program Studi DKV</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200 stagger">
            {dosen.map(d => (
              <div class="card-line bg-white hover:bg-[#FAFAF8] p-5 flex gap-4 group">
                <div class="w-10 h-10 flex items-center justify-center font-black text-white text-sm shrink-0"
                     style="background:var(--dark)">{d.nama.split(' ').find(w => /[A-Z]/.test(w[0]) && w.length > 2)?.charAt(0) || 'D'}</div>
                <div>
                  <div class="font-bold text-neutral-900 text-sm leading-tight">{d.nama}</div>
                  <div class="text-xs mt-0.5" style="color:var(--brand)">{d.keahlian}</div>
                  <div class="text-xs text-neutral-400 mt-0.5">NIDN: {d.nidn}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <!-- CTA -->
        <div class="puzzle-dark p-7" style="background:var(--dark);border-radius:2px;position:sticky;top:80px">
          <p class="label-tag mb-3">Tertarik Kuliah di DKV?</p>
          <h3 class="text-xl font-black text-white mb-3 tracking-tight">Wujudkan Karir Desainmu</h3>
          <p class="text-neutral-400 text-xs mb-5 leading-relaxed">Daftar sekarang dan bergabung dengan komunitas desainer terbaik Indonesia.</p>
          <a href="/pmb" class="btn-primary w-full justify-center mb-3">Daftar Sekarang</a>
          <a href="https://wa.me/6281388888888" target="_blank" rel="noopener noreferrer"
             class="btn-outline-white w-full justify-center text-xs py-2.5">Chat WhatsApp</a>
        </div>

        <!-- Akreditasi badge -->
        <div class="border border-green-200 bg-green-50 p-5" style="border-radius:2px">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 bg-green-500 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <div class="font-black text-green-800 text-sm">Terakreditasi BAN-PT</div>
              <div class="text-[10px] text-green-600">LAMDIK / BAN-PT</div>
            </div>
          </div>
          <div class="text-2xl font-black text-green-700">Baik Sekali</div>
          <div class="text-xs text-green-500 mt-0.5">Berlaku hingga 2028</div>
          <a href="/akreditasi" class="text-xs font-semibold text-green-700 hover:underline mt-2 block">Lihat sertifikat →</a>
        </div>

        <!-- Dokumen -->
        <div class="border border-neutral-200 bg-white p-5" style="border-radius:2px">
          <h4 class="text-[10px] font-black uppercase tracking-widest text-neutral-500 mb-4">Dokumen Program</h4>
          {['Buku Pedoman Akademik DKV', 'Kurikulum DKV 2024', 'Profil Program Studi', 'Sertifikat Akreditasi'].map(d => (
            <a href="#" class="flex items-center gap-2.5 py-2.5 border-b border-neutral-100 last:border-0 group text-sm text-neutral-600 hover:text-[var(--brand)] transition-colors">
              <svg class="w-3.5 h-3.5 shrink-0 text-neutral-300 group-hover:text-[var(--brand)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              {d}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>


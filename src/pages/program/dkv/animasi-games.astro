---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;

const matkul = [
  { kode: 'DKV301', nama: 'Animasi 2D & Frame-by-Frame',    desc: 'Teknik animasi tradisional dan digital — timing, spacing, dan prinsip 12 animasi.' },
  { kode: 'DKV302', nama: 'Animasi 3D & Pipeline',          desc: 'Modeling, rigging, skinning, rendering, dan compositing menggunakan Blender & Maya.' },
  { kode: 'DKV303', nama: 'Game Design & Development',      desc: 'Desain mekanik game, level design, prototipe, dan pengembangan dengan Unity/Unreal.' },
  { kode: 'DKV304', nama: 'Motion Graphics & VFX',          desc: 'Animasi tipografi, elemen UI, dan efek visual untuk broadcast & konten digital.' },
  { kode: 'DKV305', nama: 'Character & Creature Design',    desc: 'Desain karakter 2D/3D: proporsi, ekspresi, kostum, dan konsep visual world-building.' },
  { kode: 'DKV306', nama: 'Proyek Animasi Terpadu',         desc: 'Produksi film pendek animasi dari script, storyboard, hingga deliverable final.' },
];

const karir = [
  { title: 'Animator 2D / 3D',    desc: 'Studio animasi, rumah produksi, agency iklan, dan platform konten digital.', icon: '🎬' },
  { title: 'Game Designer',        desc: 'Studio game lokal & internasional — desain mekanik, level, dan narasi game.', icon: '🎮' },
  { title: 'Motion Designer',      desc: 'Iklan TVC, konten media sosial, opening title film, dan broadcast graphics.', icon: '✨' },
  { title: 'VFX & Compositing Artist', desc: 'Post-production house, film layar lebar, sinetron, dan platform streaming.', icon: '🎥' },
];

const tools = ['Blender', 'Adobe After Effects', 'Adobe Animate', 'Unity', 'Unreal Engine', 'Maya', 'ZBrush', 'DaVinci Resolve'];
---

<Layout
  title="Animasi & Games — Konsentrasi DKV STMK Trisakti"
  description="Konsentrasi Animasi & Games di Program S1 DKV STMK Trisakti. Kuasai animasi 2D/3D, game design, motion graphics, dan VFX bersama praktisi industri."
>

  <PageHeader
    label="Konsentrasi DKV"
    title="Animasi & Games"
    desc="Hidupkan karakter, bangun dunia virtual, dan ciptakan game yang menggerakkan pemain."
    breadcrumb={[
      { label: 'Program', href: url('/program') },
      { label: 'DKV', href: url('/program/dkv') },
      { label: 'Animasi & Games', href: '' },
    ]}
    accent="purple"
  />

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Main -->
      <div class="lg:col-span-2 space-y-16">

        <!-- About -->
        <div class="reveal">
          <p class="section-num mb-4">Tentang Konsentrasi</p>
          <h2 class="text-3xl font-black tracking-tight text-neutral-950 mb-6 leading-tight">
            Dari Sketsa ke Layar —<br/>
            <span style="color:var(--neon-purple)">Animasi & Game Kelas Industri</span>
          </h2>
          <div class="space-y-4 text-sm text-neutral-600 leading-relaxed max-w-2xl">
            <p>Konsentrasi Animasi &amp; Games mempersiapkan mahasiswa untuk memasuki industri hiburan digital yang tumbuh pesat. Mulai dari animasi karakter 2D klasik hingga pipeline produksi 3D penuh skala studio, mahasiswa belajar langsung dari animator dan game designer yang aktif di industri.</p>
            <p>Selain animasi film dan iklan, kurikulum mencakup desain dan pengembangan game — dari konsep mekanik hingga prototipe playable. Mahasiswa akan memiliki portofolio produksi nyata: film pendek animasi, motion reel, dan demo game yang siap dipresentasikan ke studio.</p>
          </div>
        </div>

        <!-- Software & Tools -->
        <div class="reveal">
          <p class="section-num mb-4">Tools yang Dipelajari</p>
          <div class="flex flex-wrap gap-2">
            {tools.map(t => (
              <span class="badge-neon-purple text-xs font-bold px-4 py-2" style="border-radius:3px">{t}</span>
            ))}
          </div>
        </div>

        <!-- Mata Kuliah Unggulan -->
        <div class="reveal">
          <p class="section-num mb-4">Mata Kuliah Unggulan</p>
          <h2 class="text-2xl font-black tracking-tight text-neutral-950 mb-8">6 Mata Kuliah Inti Konsentrasi</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200 stagger">
            {matkul.map(m => (
              <div class="bg-white p-6 group hover:bg-[#FAFAF8] transition-colors border-l-2 border-transparent hover:border-l-2"
                   style="--hover-border:var(--neon-purple)">
                <div class="text-[10px] font-black uppercase tracking-widest mb-2" style="color:var(--neon-purple)">{m.kode}</div>
                <h3 class="font-black text-neutral-950 text-sm mb-2 leading-tight">{m.nama}</h3>
                <p class="text-xs text-neutral-500 leading-relaxed">{m.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Karir -->
        <div class="reveal">
          <p class="section-num mb-4">Prospek Karir</p>
          <h2 class="text-2xl font-black tracking-tight text-neutral-950 mb-8">Mau Jadi Apa Setelah Lulus?</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 stagger">
            {karir.map(k => (
              <div class="border border-neutral-200 bg-white p-6 hover:border-neutral-300 hover:shadow-md transition-all" style="border-radius:2px">
                <div class="text-3xl mb-3">{k.icon}</div>
                <h3 class="font-black text-neutral-950 text-sm mb-2">{k.title}</h3>
                <p class="text-xs text-neutral-500 leading-relaxed">{k.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA mobile -->
        <div class="lg:hidden reveal">
          <div class="puzzle-dark p-7" style="background:var(--dark);border-radius:2px">
            <p class="label-tag mb-3">Tertarik di Animasi & Games?</p>
            <h3 class="text-xl font-black text-white mb-4 tracking-tight">Mulai Perjalanan Kreatifmu</h3>
            <a href={url('/pmb')} class="btn-primary w-full justify-center mb-3">Daftar Sekarang</a>
            <a href="https://wa.me/6287742997808" target="_blank" rel="noopener noreferrer"
               class="btn-outline-white w-full justify-center text-xs py-2.5">Chat WhatsApp</a>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="hidden lg:block space-y-4">
        <div class="puzzle-dark p-7" style="background:var(--dark);border-radius:2px;position:sticky;top:80px">
          <p class="label-tag mb-3">Tertarik di Animasi & Games?</p>
          <h3 class="text-xl font-black text-white mb-3 tracking-tight">Mulai Perjalanan Kreatifmu</h3>
          <p class="text-neutral-400 text-xs mb-5 leading-relaxed">Bergabung dengan komunitas animator dan game designer STMK Trisakti.</p>
          <a href={url('/pmb')} class="btn-primary w-full justify-center mb-3">Daftar Sekarang</a>
          <a href="https://wa.me/6287742997808" target="_blank" rel="noopener noreferrer"
             class="btn-outline-white w-full justify-center text-xs py-2.5">Chat WhatsApp</a>
        </div>

        <div class="border border-neutral-200 bg-white p-5" style="border-radius:2px">
          <h4 class="text-[10px] font-black uppercase tracking-widest text-neutral-500 mb-4">Konsentrasi Lain di DKV</h4>
          {[
            { label: 'Multimedia Penyiaran',  href: url('/program/dkv/multimedia-penyiaran') },
            { label: 'Multimedia Periklanan', href: url('/program/dkv/multimedia-periklanan') },
            { label: 'Desain Produk Kemasan', href: url('/program/dkv/desain-produk-kemasan') },
          ].map(l => (
            <a href={l.href} class="flex items-center justify-between py-2.5 border-b border-neutral-100 last:border-0 text-sm text-neutral-600 hover:text-[var(--brand)] transition-colors group">
              <span>{l.label}</span>
              <svg class="w-3.5 h-3.5 text-neutral-300 group-hover:text-[var(--brand)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>

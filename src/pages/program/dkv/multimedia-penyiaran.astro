---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}${path.startsWith('/') ? path : '/' + path}`;

const matkul = [
  { kode: 'DKV311', nama: 'Produksi Video & Videografi',    desc: 'Teknik pengambilan gambar, lighting, komposisi, dan directing untuk video konten dan siaran.' },
  { kode: 'DKV312', nama: 'Desain Grafis Siaran',           desc: 'Lower third, bumper, transisi, dan elemen visual broadcast untuk TV dan platform streaming.' },
  { kode: 'DKV313', nama: 'Audio Production & Podcast',     desc: 'Rekaman, mixing, mastering, dan produksi konten audio untuk media digital.' },
  { kode: 'DKV314', nama: 'Motion Broadcast & Title Design', desc: 'Opening title, typography in motion, dan identitas visual untuk program siaran.' },
  { kode: 'DKV315', nama: 'Digital Storytelling',           desc: 'Narasi visual multi-platform: script, storyboard, editing, dan distribusi konten.' },
  { kode: 'DKV316', nama: 'Proyek Produksi Multimedia',     desc: 'Produksi konten end-to-end dari brief kreatif hingga penayangan di platform digital.' },
];

const karir = [
  { title: 'Content Creator & Videographer', desc: 'Produksi konten untuk YouTube, Instagram, TikTok, dan platform streaming.', icon: '📹' },
  { title: 'Broadcast & Motion Designer',     desc: 'Desain visual untuk stasiun TV, OTT platform, dan produksi film.', icon: '📺' },
  { title: 'Video Editor & Colorist',         desc: 'Post-production house, production company, dan agensi kreatif.', icon: '🎞️' },
  { title: 'Podcast & Audio Producer',        desc: 'Studio podcast, radio digital, dan platform konten audio berbasis brand.', icon: '🎙️' },
];

const tools = ['Adobe Premiere Pro', 'Adobe After Effects', 'DaVinci Resolve', 'Adobe Audition', 'Final Cut Pro', 'OBS Studio', 'Adobe Media Encoder'];
---

<Layout
  title="Multimedia Penyiaran — Konsentrasi DKV STMK Trisakti"
  description="Konsentrasi Multimedia Penyiaran di S1 DKV STMK Trisakti. Kuasai produksi video, broadcast design, podcast, dan konten digital dari studio profesional."
>

  <PageHeader
    label="Konsentrasi DKV"
    title="Multimedia Penyiaran"
    desc="Produksi konten digital dan broadcast yang menjangkau jutaan audiens di era media baru."
    breadcrumb={[
      { label: 'Program', href: url('/program') },
      { label: 'DKV', href: url('/program/dkv') },
      { label: 'Multimedia Penyiaran', href: '' },
    ]}
    accent="cyan"
  />

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Main -->
      <div class="lg:col-span-2 space-y-16">

        <!-- About -->
        <div class="reveal">
          <p class="section-num mb-4">Tentang Konsentrasi</p>
          <h2 class="text-3xl font-black tracking-tight text-neutral-950 mb-6 leading-tight">
            Dari Studio ke Layar —<br/>
            <span style="color:var(--neon-cyan)">Konten yang Bicara ke Jutaan Orang</span>
          </h2>
          <div class="space-y-4 text-sm text-neutral-600 leading-relaxed max-w-2xl">
            <p>Konsentrasi Multimedia Penyiaran mengajarkan mahasiswa seluruh pipeline produksi konten digital dan siaran — dari perencanaan kreatif, shooting, pasca-produksi, hingga distribusi di platform digital. Mahasiswa mendapat akses langsung ke studio podcast dan ruang produksi video STMK Trisakti yang berstandar industri.</p>
            <p>Di era media baru, batas antara konten digital dan siaran tradisional semakin kabur. Konsentrasi ini membekali mahasiswa untuk berkarya di keduanya — mulai dari YouTube dan podcast hingga stasiun TV dan platform OTT.</p>
          </div>
        </div>

        <!-- Tools -->
        <div class="reveal">
          <p class="section-num mb-4">Tools yang Dipelajari</p>
          <div class="flex flex-wrap gap-2">
            {tools.map(t => (
              <span class="badge-neon-cyan text-xs font-bold px-4 py-2" style="border-radius:3px">{t}</span>
            ))}
          </div>
        </div>

        <!-- Mata Kuliah -->
        <div class="reveal">
          <p class="section-num mb-4">Mata Kuliah Unggulan</p>
          <h2 class="text-2xl font-black tracking-tight text-neutral-950 mb-8">6 Mata Kuliah Inti Konsentrasi</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-neutral-200 stagger">
            {matkul.map(m => (
              <div class="bg-white p-6 hover:bg-[#FAFAF8] transition-colors">
                <div class="text-[10px] font-black uppercase tracking-widest mb-2" style="color:var(--neon-cyan)">{m.kode}</div>
                <h3 class="font-black text-neutral-950 text-sm mb-2 leading-tight">{m.nama}</h3>
                <p class="text-xs text-neutral-500 leading-relaxed">{m.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Karir -->
        <div class="reveal">
          <p class="section-num mb-4">Prospek Karir</p>
          <h2 class="text-2xl font-black tracking-tight text-neutral-950 mb-8">Mau Jadi Apa Setelah Lulus?</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 stagger">
            {karir.map(k => (
              <div class="border border-neutral-200 bg-white p-6 hover:border-neutral-300 hover:shadow-md transition-all" style="border-radius:2px">
                <div class="text-3xl mb-3">{k.icon}</div>
                <h3 class="font-black text-neutral-950 text-sm mb-2">{k.title}</h3>
                <p class="text-xs text-neutral-500 leading-relaxed">{k.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA mobile -->
        <div class="lg:hidden reveal">
          <div class="puzzle-dark p-7" style="background:var(--dark);border-radius:2px">
            <p class="label-tag mb-3">Tertarik di Multimedia Penyiaran?</p>
            <h3 class="text-xl font-black text-white mb-4 tracking-tight">Mulai Produksi Kontenmu</h3>
            <a href={url('/pmb')} class="btn-primary w-full justify-center mb-3">Daftar Sekarang</a>
            <a href="https://wa.me/6287742997808" target="_blank" rel="noopener noreferrer"
               class="btn-outline-white w-full justify-center text-xs py-2.5">Chat WhatsApp</a>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="hidden lg:block space-y-4">
        <div class="puzzle-dark p-7" style="background:var(--dark);border-radius:2px;position:sticky;top:80px">
          <p class="label-tag mb-3">Tertarik di Penyiaran?</p>
          <h3 class="text-xl font-black text-white mb-3 tracking-tight">Mulai Produksi Kontenmu</h3>
          <p class="text-neutral-400 text-xs mb-5 leading-relaxed">Studio podcast dan ruang produksi video menunggumu di kampus.</p>
          <a href={url('/pmb')} class="btn-primary w-full justify-center mb-3">Daftar Sekarang</a>
          <a href="https://wa.me/6287742997808" target="_blank" rel="noopener noreferrer"
             class="btn-outline-white w-full justify-center text-xs py-2.5">Chat WhatsApp</a>
        </div>

        <div class="border border-neutral-200 bg-white p-5" style="border-radius:2px">
          <h4 class="text-[10px] font-black uppercase tracking-widest text-neutral-500 mb-4">Konsentrasi Lain di DKV</h4>
          {[
            { label: 'Animasi & Games',        href: url('/program/dkv/animasi-games') },
            { label: 'Multimedia Periklanan',  href: url('/program/dkv/multimedia-periklanan') },
          ].map(l => (
            <a href={l.href} class="flex items-center justify-between py-2.5 border-b border-neutral-100 last:border-0 text-sm text-neutral-600 hover:text-[var(--brand)] transition-colors group">
              <span>{l.label}</span>
              <svg class="w-3.5 h-3.5 text-neutral-300 group-hover:text-[var(--brand)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
